[
  {
    "name": "theme_info",
    "theme_name": "FachWissenBau",
    "theme_version": "1.0.0",
    "theme_author": "FachWissenBau",
    "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
    "theme_support_url": "https://support.shopify.com/"
  },
  {
    "name": "Schrift",
    "settings": [
      {
        "type": "header",
        "content": "Überschriften"
      },
      {
        "type": "font_picker",
        "id": "heading_font",
        "default": "inter_n3",
        "label": "Überschriften Schrift"
      },
      {
        "type": "header",
        "content": "Fliesstext"
      },
      {
        "type": "font_picker",
        "id": "body_font",
        "default": "inter_n4",
        "label": "Text Schrift"
      },
      {
        "type": "header",
        "content": "Schriftgrössen"
      },
      {
        "type": "range",
        "id": "base_font_size",
        "min": 14,
        "max": 20,
        "step": 1,
        "unit": "px",
        "label": "Basis-Schriftgrösse",
        "default": 16
      }
    ]
  },
  {
    "name": "Farben",
    "settings": [
      {
        "type": "color",
        "id": "color_primary",
        "default": "#0d0d0d",
        "label": "Primärfarbe (Schwarz)"
      },
      {
        "type": "color",
        "id": "color_background",
        "default": "#ffffff",
        "label": "Hintergrundfarbe"
      },
      {
        "type": "color",
        "id": "color_surface",
        "default": "#f7f7f5",
        "label": "Oberflächen-Farbe (Grau)"
      },
      {
        "type": "color",
        "id": "color_text",
        "default": "#1a1a18",
        "label": "Textfarbe"
      },
      {
        "type": "color",
        "id": "color_text_muted",
        "default": "#888886",
        "label": "Gedämpfte Textfarbe"
      },
      {
        "type": "color",
        "id": "color_border",
        "default": "#efefed",
        "label": "Rahmenfarbe"
      }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "select",
        "id": "max_page_width",
        "label": "Maximale Seitenbreite",
        "options": [
          { "value": "90rem", "label": "Schmal (1440px)" },
          { "value": "100rem", "label": "Normal (1600px)" },
          { "value": "110rem", "label": "Breit (1760px)" }
        ],
        "default": "90rem"
      },
      {
        "type": "range",
        "id": "min_page_margin",
        "min": 10,
        "max": 80,
        "step": 5,
        "unit": "px",
        "label": "Seiten-Abstand",
        "default": 20
      },
      {
        "type": "range",
        "id": "section_padding",
        "min": 40,
        "max": 160,
        "step": 10,
        "unit": "px",
        "label": "Abschnitt-Abstände (Basis)",
        "default": 80
      }
    ]
  },
  {
    "name": "Buttons",
    "settings": [
      {
        "type": "range",
        "id": "button_border_radius",
        "min": 0,
        "max": 40,
        "step": 2,
        "unit": "px",
        "label": "Button Eckenradius",
        "default": 0
      },
      {
        "type": "range",
        "id": "input_corner_radius",
        "min": 0,
        "max": 10,
        "step": 1,
        "unit": "px",
        "label": "Eingabefeld Eckenradius",
        "default": 0
      }
    ]
  }
]
