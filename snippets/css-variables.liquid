{% style %}
  {% comment %} Load heading font faces {% endcomment %}
  {{ settings.heading_font | font_face: font_display: 'swap' }}
  {{ settings.heading_font | font_modify: 'weight', 'bold' | font_face: font_display: 'swap' }}
  {{ settings.heading_font | font_modify: 'style', 'italic' | font_face: font_display: 'swap' }}
  {{ settings.heading_font | font_modify: 'weight', 'bold' | font_modify: 'style', 'italic' | font_face: font_display: 'swap' }}

  {% comment %} Load body font faces {% endcomment %}
  {{ settings.body_font | font_face: font_display: 'swap' }}
  {{ settings.body_font | font_modify: 'weight', 'bold' | font_face: font_display: 'swap' }}
  {{ settings.body_font | font_modify: 'style', 'italic' | font_face: font_display: 'swap' }}

  :root {
    {% comment %} Legacy skeleton vars {% endcomment %}
    --page-width: {{ settings.max_page_width }};
    --page-margin: {{ settings.min_page_margin }}px;
    --style-border-radius-inputs: {{ settings.input_corner_radius }}px;

    {% comment %} FachWissenBau — all tokens driven by theme settings {% endcomment %}
    --fwb-white: #ffffff;
    --fwb-black: {{ settings.color_primary }};
    --fwb-grey-100: {{ settings.color_surface }};
    --fwb-grey-200: {{ settings.color_border }};
    --fwb-grey-300: #d8d8d6;
    --fwb-grey-500: {{ settings.color_text_muted }};
    --fwb-grey-700: #444442;
    --fwb-text: {{ settings.color_text }};
    --fwb-bg: {{ settings.color_background }};

    --fwb-font-heading: {{ settings.heading_font.family }}, {{ settings.heading_font.fallback_families }};
    --fwb-font-heading-weight: {{ settings.heading_font.weight }};
    --fwb-font-heading-style: {{ settings.heading_font.style }};
    --fwb-font-body: {{ settings.body_font.family }}, {{ settings.body_font.fallback_families }};
    --fwb-font-body-weight: {{ settings.body_font.weight }};
    --fwb-font-body-style: {{ settings.body_font.style }};

    --fwb-base-size: {{ settings.base_font_size }}px;
    --fwb-max-w: {{ settings.max_page_width }};
    --fwb-gutter: clamp({{ settings.min_page_margin }}px, 5vw, {{ settings.min_page_margin | times: 4 }}px);
    --fwb-section-pad: clamp({{ settings.section_padding | times: 0.6 | round }}px, 8vw, {{ settings.section_padding }}px);
    --fwb-transition: 0.22s ease;
    --fwb-btn-radius: {{ settings.button_border_radius }}px;
  }
{% endstyle %}
