    "product_authors": {
      "type": "product-authors",
      "blocks": {
        "author_01": {
          "type": "author",
          "settings": {
            "name": "Heinz Ehrbar",
            "role": "Autor",
            "credentials": "Dipl. Bauingenieur ETH/SIA",
            "bio": "Seit 1981 auf dem Gebiet des Untertagbaus tätig, während rund 20 Jahren bei der Planung und Realisierung von Wasserkraftanlagen in der Schweiz und im Ausland. 1996 Wechsel in den Verkehrstunnelbau als Projektleiter für den Teilabschnitt Sedrun des Gotthard-Basistunnels, ab 2001 stellvertretender Leiter und ab 2006 Leiter Tunnel- und Trasseebau Gotthard-Basistunnel und Mitglied der Geschäftsleitung der AlpTransit Gotthard AG. 2013 bis 2017 Leiter Management Grossprojekte bei der DB Netz AG, Frankfurt am Main. Lehraufträge an der RWTH Aachen (2014 bis 2021) und an der ETH Zürich (2017 bis 2022) für Baubetrieb im Tunnelbau und Organisation von Untertagbauprojekten. Heute Inhaber einer eigenen Beratungsfirma. Nebenamtliche Aktivitäten als Vorstandsmitglied der FGU (2004 bis 2016), Leiter ITA-Working Group 19 «Conventional Tunnelling» (2004 bis 2016) und Mitglied des DAUB (seit 2016).",
            "image_asset": "author-heinz-ehrbar.jpg"
          }
        },
        "author_02": {
          "type": "author",
          "settings": {
            "name": "Olivier Böckli",
            "role": "Autor",
            "credentials": "Dipl. Bauingenieur ETH/SIA, EMBA in Leadership and Sustainability",
            "bio": "Knapp 30 Jahre Berufserfahrung in der Geschäftsführung und Ausführung von Tunnelbauprojekten in der Schweiz und im Ausland. Funktionen unter anderem als Baustellenchef am Gotthard-Basistunnel, als Geschäftsführer der Implenia Frankreich für vier Metrotunnel-Baulose am Grand-Paris-Express-Projekt und in Lyon sowie für zwei grosse Microtunnelling-Projekte im Mittleren Osten. Heute Mitglied der Geschäftsleitung der Marti Tunnel AG, verantwortlich für die Infrastrukturprojekte in Skandinavien, in der Slowakei sowie für die Entwicklung neuer Märkte für die Marti-Tunnelgruppe.",
            "image_asset": "author-olivier-boeckli.jpg"
          }
        },
        "author_03": {
          "type": "author",
          "settings": {
            "name": "Christian Ammon",
            "role": "Autor",
            "credentials": "Dipl. Kulturingenieur ETH/SIA",
            "bio": "37 Jahre Baubetriebserfahrung in der Ausführung von Tunnelbauprojekten in den Funktionen Bauführung, Baustellenchef und Projektleiter sowie 20 Jahre Geschäftsleitungsmitglied der Rothpletz, Lienhard + Cie AG und verantwortlicher Abteilungsleiter Tunnelbau. Verantwortlich für massgebende Infrastrukturprojekte mit allen gängigen Methoden des bergmännischen Tunnelbaus und anspruchsvolles Vertragsmanagement mit privaten, institutionellen und internationalen Vertragspartnern. Vier Jahre Mitwirkung in der Baupraxis-orientierten Ausbildung der Masterstudien D-BAUG ETH Zürich unter Einbezug gelebter Berufserfahrung.",
            "image_asset": "author-christian-ammon.jpg"
          }
        }
      },
