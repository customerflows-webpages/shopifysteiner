<div class="fwb-verlag">
  <div class="fwb-wrap">

    <div class="fwb-verlag__header">
      {%- if section.settings.label != blank -%}
        <p class="fwb-label">{{ section.settings.label }}</p>
      {%- endif -%}
      <h1 class="fwb-display fwb-verlag__title">{{ collection.title | default: 'Verlag' }}</h1>
      {%- if section.settings.subtitle != blank -%}
        <p class="fwb-verlag__subtitle fwb-body">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    <div class="fwb-verlag__grid" style="--cols:{{ section.settings.columns }}">
      {%- assign ordered_handles = 'baupraxis-oeffentliche-beschaffung,baupraxis-tief-und-strassenbau,baupraxis-verkehrswegbau-die-projektierung,baupraxis-der-untertagbau,bim-in-der-praxis' | split: ',' -%}
      {%- for handle in ordered_handles -%}
        {%- assign product = all_products[handle] -%}
        {%- unless product == empty -%}
        <article class="fwb-verlag__card">
          <a href="{{ product.url }}" class="fwb-verlag__card-image">
            {%- if product.featured_image != blank -%}
              <img
                src="{{ product.featured_image | img_url: '900x' }}"
                alt="{{ product.featured_image.alt | default: product.title | escape }}"
                loading="lazy"
              >
            {%- else -%}
              <div class="fwb-verlag__card-placeholder"></div>
            {%- endif -%}
            <div class="fwb-verlag__card-overlay">
              <span class="fwb-label">{{ section.settings.card_hover_label | default: 'Mehr erfahren →' }}</span>
            </div>
          </a>
          <div class="fwb-verlag__card-info">
            <h2 class="fwb-verlag__card-title">{% render 'book-title', title: product.title %}</h2>
            <p class="fwb-verlag__card-price">ab {{ product.price_min | money }}</p>
            <p class="fwb-verlag__card-desc fwb-body">{{ product.description | strip_html | truncate: 110 }}</p>
            <a href="{{ product.url }}" class="fwb-btn fwb-verlag__card-btn">{{ section.settings.card_btn_label | default: 'Mehr erfahren' }}</a>
          </div>
        </article>
        {%- endunless -%}
      {%- endfor -%}
    </div>

  </div>
</div>

{% stylesheet %}
  .fwb-verlag { padding-bottom: var(--fwb-section-pad); }

  .fwb-verlag__header {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding-block: clamp(4rem, 8vw, 9rem);
    border-bottom: 1px solid var(--fwb-grey-200);
    margin-bottom: clamp(3rem, 6vw, 6rem);
    max-width: 640px;
  }

  .fwb-verlag__title {
    font-style: italic;
  }

  .fwb-verlag__subtitle {
    max-width: 480px;
  }

  .fwb-verlag__grid {
    display: grid;
    grid-template-columns: repeat(var(--cols, 2), 1fr);
    gap: clamp(3rem, 6vw, 6rem) clamp(2rem, 5vw, 5rem);
  }

  .fwb-verlag__card {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    height: 100%;
  }

  .fwb-verlag__card-image {
    display: block;
    overflow: hidden;
    position: relative;
    aspect-ratio: 4/5;
    background: var(--fwb-grey-100);
  }

  .fwb-verlag__card-image img {
    width: 100%;
    height: 100%;
    padding: clamp(0.75rem, 2vw, 1.5rem);
    object-fit: contain;
    transition: transform 0.55s ease;
    display: block;
  }

  .fwb-verlag__card-placeholder {
    aspect-ratio: 4/5;
    background: var(--fwb-grey-200);
  }

  .fwb-verlag__card:hover .fwb-verlag__card-image img {
    transform: scale(1.035);
  }

  .fwb-verlag__card-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .fwb-verlag__card-overlay .fwb-label {
    color: var(--fwb-white);
    letter-spacing: 0.18em;
  }

  .fwb-verlag__card:hover .fwb-verlag__card-overlay { opacity: 1; }

  .fwb-verlag__card-info {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    flex: 1;
  }

  .fwb-verlag__card-title {
    font-family: var(--fwb-font-heading);
    font-size: clamp(1.1rem, 1.6vw, 1.45rem);
    font-weight: 400;
    line-height: 1.28;
    color: var(--fwb-black);
  }

  .fwb-verlag__card-price {
    font-size: 0.75rem;
    color: var(--fwb-grey-500);
    letter-spacing: 0.03em;
  }

  .fwb-verlag__card-desc {
    font-size: 0.83rem;
    line-height: 1.75;
    color: var(--fwb-grey-500);
    margin-top: 0.2rem;
  }

  .fwb-verlag__card-btn {
    align-self: flex-start;
    margin-top: auto;
    padding-top: 0.5rem;
    font-size: 0.62rem;
    letter-spacing: 0.14em;
  }

  @media (max-width: 900px) {
    .fwb-verlag__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 560px) {
    .fwb-verlag__grid { grid-template-columns: 1fr; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Verlag Kollektion",
  "settings": [
    { "type": "text", "id": "label", "label": "Label", "default": "FachWissenBau" },
    { "type": "textarea", "id": "subtitle", "label": "Untertitel", "default": "Fachpublikationen für die Schweizer Bauwirtschaft – präzise, praxisnah und nachhaltig relevant." },
    {
      "type": "select", "id": "columns", "label": "Spalten",
      "options": [
        { "value": "1", "label": "1 Spalte" },
        { "value": "2", "label": "2 Spalten" },
        { "value": "3", "label": "3 Spalten" },
        { "value": "4", "label": "4 Spalten" }
      ],
      "default": "4"
    },
    { "type": "text", "id": "card_hover_label", "label": "Karte Hover-Text", "default": "Mehr erfahren →" },
    { "type": "text", "id": "card_btn_label", "label": "Karte Button Text", "default": "Mehr erfahren" }
  ],
  "presets": [{ "name": "Verlag Kollektion" }]
}
{% endschema %}
