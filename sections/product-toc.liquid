<div class="fwb-toc">
  <div class="fwb-wrap fwb-toc__inner">

    <div class="fwb-toc__header">
      <p class="fwb-label">{{ section.settings.label | default: 'Inhaltsverzeichnis' }}</p>
      <h2 class="fwb-h2 fwb-toc__title">{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="fwb-body fwb-toc__sub">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="fwb-toc__list">
      {%- for block in section.blocks -%}
        {%- assign has_subs = false -%}
        {%- if block.settings.sub_chapters != blank -%}
          {%- assign has_subs = true -%}
        {%- endif -%}

        <div class="fwb-toc__chapter" {{ block.shopify_attributes }}>
          {%- if has_subs -%}
            <button
              class="fwb-toc__chapter-btn"
              aria-expanded="false"
              aria-controls="fwb-toc-{{ block.id }}"
            >
              <span class="fwb-toc__number">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
              <span class="fwb-toc__chapter-title">{{ block.settings.chapter }}</span>
              <span class="fwb-toc__icon" aria-hidden="true"></span>
            </button>
            <div class="fwb-toc__subs" id="fwb-toc-{{ block.id }}">
              <ul class="fwb-toc__sub-list">
                {%- assign sub_lines = block.settings.sub_chapters | newline_to_br | split: '<br />' -%}
                {%- for sub in sub_lines -%}
                  {%- assign sub_clean = sub | strip | strip_html -%}
                  {%- unless sub_clean == blank -%}
                    <li class="fwb-toc__sub-item">{{ sub_clean }}</li>
                  {%- endunless -%}
                {%- endfor -%}
              </ul>
            </div>
          {%- else -%}
            <div class="fwb-toc__chapter-row">
              <span class="fwb-toc__number">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
              <span class="fwb-toc__chapter-title">{{ block.settings.chapter }}</span>
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

  </div>
</div>

<script>
  document.querySelectorAll('.fwb-toc__chapter-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var isOpen = btn.getAttribute('aria-expanded') === 'true';
      var subs = document.getElementById(btn.getAttribute('aria-controls'));
      btn.setAttribute('aria-expanded', String(!isOpen));
      if (subs) subs.classList.toggle('is-open', !isOpen);
    });
  });
</script>

{% stylesheet %}
  .fwb-toc {
    padding-block: var(--fwb-section-pad);
    background: var(--fwb-grey-100);
  }

  .fwb-toc__inner {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: clamp(3rem, 6vw, 8rem);
    align-items: start;
  }

  .fwb-toc__header {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: sticky;
    top: 100px;
  }

  .fwb-toc__title {
    font-style: italic;
  }

  .fwb-toc__sub {
    font-size: 0.85rem;
    line-height: 1.7;
    max-width: 360px;
  }

  .fwb-toc__list {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--fwb-grey-300);
  }

  .fwb-toc__chapter {
    border-bottom: 1px solid var(--fwb-grey-300);
  }

  /* Plain row (no sub-chapters) */
  .fwb-toc__chapter-row {
    display: flex;
    align-items: baseline;
    gap: 1.5rem;
    padding-block: 1.1rem;
    padding-inline: 0.25rem;
  }

  /* Button row (has sub-chapters) */
  .fwb-toc__chapter-btn {
    width: 100%;
    display: flex;
    align-items: baseline;
    gap: 1.5rem;
    padding-block: 1.1rem;
    padding-inline: 0.25rem;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    font-family: inherit;
    transition: background var(--fwb-transition), padding var(--fwb-transition);
  }

  .fwb-toc__chapter-btn:hover {
    background: var(--fwb-grey-200);
    padding-inline: 0.75rem;
  }

  .fwb-toc__number {
    font-family: var(--fwb-font-heading);
    font-size: 0.75rem;
    color: var(--fwb-grey-500);
    min-width: 28px;
    flex-shrink: 0;
  }

  .fwb-toc__chapter-title {
    font-family: var(--fwb-font-body);
    font-size: 0.875rem;
    font-weight: 400;
    color: var(--fwb-text);
    letter-spacing: 0.01em;
    flex: 1;
  }

  /* +/- icon */
  .fwb-toc__icon {
    display: block;
    width: 12px;
    height: 12px;
    position: relative;
    flex-shrink: 0;
    margin-left: auto;
    align-self: center;
  }

  .fwb-toc__icon::before,
  .fwb-toc__icon::after {
    content: '';
    position: absolute;
    background: var(--fwb-grey-500);
    transition: transform 0.25s ease, opacity 0.25s ease;
  }

  .fwb-toc__icon::before {
    width: 12px; height: 1px;
    top: 50%; left: 0;
    transform: translateY(-50%);
  }

  .fwb-toc__icon::after {
    width: 1px; height: 12px;
    top: 0; left: 50%;
    transform: translateX(-50%);
  }

  .fwb-toc__chapter-btn[aria-expanded="true"] .fwb-toc__icon::after {
    transform: translateX(-50%) rotate(90deg);
    opacity: 0;
  }

  /* Sub-chapters panel */
  .fwb-toc__subs {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s ease;
  }

  .fwb-toc__subs.is-open {
    max-height: 2000px;
  }

  .fwb-toc__sub-list {
    list-style: none;
    padding: 0 0 1rem 1.75rem;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
    border-left: 1px solid var(--fwb-grey-300);
    margin-left: calc(28px + 1.5rem);
    margin-bottom: 0.5rem;
  }

  .fwb-toc__sub-item {
    font-size: 0.78rem;
    color: var(--fwb-grey-600, #555);
    padding: 0.35rem 0;
    line-height: 1.5;
    padding-left: 1rem;
    border-bottom: 1px solid var(--fwb-grey-200);
  }

  .fwb-toc__sub-item:last-child {
    border-bottom: none;
  }

  @media (max-width: 768px) {
    .fwb-toc__inner {
      grid-template-columns: 1fr;
    }
    .fwb-toc__header {
      position: static;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Inhaltsverzeichnis",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Inhaltsverzeichnis"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Die Kapitel im Überblick."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Unterzeile"
    }
  ],
  "blocks": [
    {
      "type": "chapter",
      "name": "Kapitel",
      "settings": [
        {
          "type": "text",
          "id": "chapter",
          "label": "Kapitelname"
        },
        {
          "type": "textarea",
          "id": "sub_chapters",
          "label": "Unterkapitel (eines pro Zeile)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Inhaltsverzeichnis",
      "blocks": [
        { "type": "chapter", "settings": { "chapter": "Einführung" } },
        { "type": "chapter", "settings": { "chapter": "Grundlagen" } },
        { "type": "chapter", "settings": { "chapter": "Ausführung" } }
      ]
    }
  ]
}
{% endschema %}
