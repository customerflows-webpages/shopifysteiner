{%- if section.blocks.size > 0 -%}
<div class="fwb-sponsors">
  <div class="fwb-wrap">

    <div class="fwb-sponsors__header">
      {%- if section.settings.label != blank -%}
        <p class="fwb-label">{{ section.settings.label }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="fwb-h2 fwb-sponsors__title">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.intro != blank -%}
        <p class="fwb-body fwb-sponsors__intro">{{ section.settings.intro }}</p>
      {%- endif -%}
    </div>

    <div class="fwb-sponsors__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'heading' -%}
          <div class="fwb-sponsors__tier-heading" {{ block.shopify_attributes }}>{{ block.settings.title }}</div>
        {%- else -%}
          <div class="fwb-sponsors__item" {{ block.shopify_attributes }}>
            {%- if block.settings.asset_name != blank or block.settings.image_url != blank or block.settings.image != blank -%}
              <div class="fwb-sponsors__logo-wrap">
                {%- if block.settings.url != blank -%}
                  <a href="{{ block.settings.url }}" target="_blank" rel="noopener" class="fwb-sponsors__logo-link">
                {%- endif -%}
                {%- if block.settings.asset_name != blank -%}
                  <img
                    src="{{ block.settings.asset_name | asset_url }}"
                    alt="{{ block.settings.name | default: 'Sponsor' }}"
                    loading="lazy"
                    class="fwb-sponsors__logo"
                    onerror="var p=this.closest('.fwb-sponsors__item');var fb=p&&p.querySelector('.fwb-sponsors__name-fallback');if(fb){fb.style.display='';this.style.display='none'}"
                  >
                {%- elsif block.settings.image_url != blank -%}
                  <img
                    src="{{ block.settings.image_url }}"
                    alt="{{ block.settings.name | default: 'Sponsor' }}"
                    loading="lazy"
                    class="fwb-sponsors__logo"
                    onerror="var p=this.closest('.fwb-sponsors__item');var fb=p&&p.querySelector('.fwb-sponsors__name-fallback');if(fb){fb.style.display='';this.style.display='none'}"
                  >
                {%- else -%}
                  <img
                    src="{{ block.settings.image | img_url: '400x' }}"
                    alt="{{ block.settings.name | default: 'Sponsor' }}"
                    loading="lazy"
                    class="fwb-sponsors__logo"
                  >
                {%- endif -%}
                {%- if block.settings.url != blank -%}
                  </a>
                {%- endif -%}
              </div>
              {%- if block.settings.name != blank -%}
                <div class="fwb-sponsors__name-fallback" style="display:none">
                  {%- if block.settings.url != blank -%}
                    <a href="{{ block.settings.url }}" target="_blank" rel="noopener">{{ block.settings.name }}</a>
                  {%- else -%}
                    {{ block.settings.name }}
                  {%- endif -%}
                </div>
              {%- endif -%}
            {%- elsif block.settings.name != blank -%}
              <div class="fwb-sponsors__name-only">
                {%- if block.settings.url != blank -%}
                  <a href="{{ block.settings.url }}" target="_blank" rel="noopener">{{ block.settings.name }}</a>
                {%- else -%}
                  {{ block.settings.name }}
                {%- endif -%}
              </div>
            {%- endif -%}
            {%- if block.settings.caption != blank -%}
              <p class="fwb-sponsors__caption">{{ block.settings.caption }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</div>
{%- endif -%}

{% stylesheet %}

  .fwb-sponsors {
    padding-block: var(--fwb-section-pad);
    background: var(--fwb-grey-100);
  }

  .fwb-sponsors__header {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: clamp(2.5rem, 5vw, 5rem);
  }

  .fwb-sponsors__title {
    font-style: italic;
  }

  .fwb-sponsors__intro {
    max-width: 640px;
    font-size: 0.9rem;
  }

  .fwb-sponsors__grid {
    display: flex;
    flex-wrap: wrap;
    gap: 3rem 4.5rem;
    align-items: center;
  }

  .fwb-sponsors__tier-heading {
    flex-basis: 100%;
    width: 100%;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--fwb-grey-500);
    padding-top: 2rem;
    border-top: 1px solid var(--fwb-grey-200);
  }

  .fwb-sponsors__tier-heading:first-child {
    padding-top: 0;
    border-top: none;
  }

  .fwb-sponsors__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    min-width: clamp(120px, 12vw, 190px);
  }

  .fwb-sponsors__logo-wrap {
    display: flex;
    align-items: center;
  }

  .fwb-sponsors__logo-link {
    display: block;
  }

  .fwb-sponsors__logo {
    max-height: 104px;
    width: auto;
    max-width: 280px;
    object-fit: contain;
    filter: grayscale(100%);
    opacity: 0.65;
    transition: filter 0.2s ease, opacity 0.2s ease;
  }

  .fwb-sponsors__logo-link:hover .fwb-sponsors__logo {
    filter: grayscale(0%);
    opacity: 1;
  }

  .fwb-sponsors__name-only,
  .fwb-sponsors__name-fallback {
    font-family: var(--fwb-font-heading);
    font-size: 1rem;
    font-weight: 300;
    color: var(--fwb-grey-700);
    letter-spacing: 0.04em;
  }

  .fwb-sponsors__name-only a,
  .fwb-sponsors__name-fallback a {
    color: inherit;
    text-decoration: none;
  }

  .fwb-sponsors__name-only a:hover,
  .fwb-sponsors__name-fallback a:hover {
    color: var(--fwb-grey-900);
  }

  .fwb-sponsors__caption {
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fwb-grey-500);
  }

  .fwb-sponsors__placeholder {
    color: var(--fwb-grey-500);
    font-style: italic;
  }

{% endstylesheet %}

{% schema %}
{
  "name": "Sponsoren",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Sponsoren"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Ermöglicht durch unsere Partner."
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Einleitungstext"
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Tier-Überschrift",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Bezeichnung",
          "default": "Platinsponsoren"
        }
      ]
    },
    {
      "type": "sponsor",
      "name": "Sponsor",
      "settings": [
        {
          "type": "text",
          "id": "asset_name",
          "label": "Logo (Theme Asset Dateiname)"
        },
        {
          "type": "text",
          "id": "image_url",
          "label": "Logo-URL (extern)"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo (hochgeladen)"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Firmenname"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Beschriftung (optional)"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Sponsoren"
    }
  ]
}
{% endschema %}
