<footer class="fwb-footer">
  <div class="fwb-footer__top-strip">
    <div class="fwb-footer__top-line"></div>
  </div>
  <div class="fwb-footer__bg">
    {%- if section.settings.bg_image != blank -%}
      <img src="{{ section.settings.bg_image | img_url: '1600x' }}" alt="" class="fwb-footer__bg-img" loading="lazy" aria-hidden="true">
    {%- else -%}
      <img src="{{ 'footer-cityscape.jpg' | asset_url }}" alt="" class="fwb-footer__bg-img" loading="lazy" aria-hidden="true">
    {%- endif -%}
    <div class="fwb-footer__overlay"></div>
  </div>

  <div class="fwb-footer__inner fwb-wrap">
    <div class="fwb-footer__brand">
      <p class="fwb-footer__shop-name">{{ section.settings.brand_name | default: shop.name }}</p>
    </div>
    <div class="fwb-footer__cols">
      <div class="fwb-footer__col">
        {%- if section.settings.address != blank -%}
          <p class="fwb-footer__col-text">{{ section.settings.address | newline_to_br }}</p>
        {%- endif -%}
      </div>
      <div class="fwb-footer__col fwb-footer__col--center">
        {% for link in section.settings.menu.links %}
          <a href="{{ link.url }}" class="fwb-footer__pill">{{ link.title }}</a>
        {% endfor %}
      </div>
      <div class="fwb-footer__col fwb-footer__col--right">
        {%- if section.settings.email != blank -%}
          <a href="mailto:{{ section.settings.email }}" class="fwb-footer__col-text">{{ section.settings.email }}</a>
        {%- endif -%}
        {%- if section.settings.linkedin_url != blank -%}
          <a href="{{ section.settings.linkedin_url }}" class="fwb-footer__social" target="_blank" rel="noopener" aria-label="LinkedIn">
            <span style="font-weight: 600; font-size: 1.1rem; line-height: 1;">in</span>
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</footer>

{% stylesheet %}
  .fwb-footer { position: relative; overflow: hidden; }
  .fwb-footer__top-strip {
    position: relative;
    z-index: 1;
    background: var(--fwb-bg, #ffffff);
    height: 48px;
    display: flex;
    align-items: flex-end;
    padding-bottom: 0;
  }
  .fwb-footer__top-line {
    width: 100%;
    height: 1px;
    background: var(--fwb-grey-200);
  }
  .fwb-footer__bg { position: absolute; inset: 0; z-index: 0; }
  .fwb-footer__bg-img { width: 100%; height: 100%; object-fit: cover; object-position: center 70%; filter: grayscale(100%) opacity(0.4); }
  .fwb-footer__overlay { display: none; }
  .fwb-footer__inner {
    position: relative;
    z-index: 1;
    padding-top: 6rem;
    padding-bottom: 6rem;
    color: var(--fwb-black);
    text-align: center;
    font-family: var(--fwb-font-body);
  }
  .fwb-footer__brand { margin-bottom: 2.5rem; }
  .fwb-footer__shop-name {
    font-family: var(--fwb-font-body);
    font-size: clamp(2rem,4vw,3.5rem);
    font-weight: 400;
    letter-spacing: 0;
    color: var(--fwb-black);
  }
  
  .fwb-footer__cols {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 2rem;
    align-items: end;
    max-width: 1200px;
    margin: 0 auto;
  }
  
  .fwb-footer__col {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 0.5rem;
    min-height: 100%;
    text-align: left;
  }
  .fwb-footer__col--center { align-items: center; gap: 0.8rem; }
  .fwb-footer__col--right { align-items: flex-end; text-align: right; }
  
  .fwb-footer__col-text {
    font-family: var(--fwb-font-body);
    font-size: clamp(0.875rem, 1vw, 0.95rem);
    font-weight: 400;
    line-height: 1.55;
    letter-spacing: 0;
    color: var(--fwb-black);
    text-decoration: none;
  }
  
  .fwb-footer__pill {
    display: inline-flex;
    justify-content: center;
    align-items: center;
    border: 1px solid var(--fwb-black);
    border-radius: var(--fwb-btn-radius, 0);
    padding: 0.7rem 2rem;
    font-family: var(--fwb-font-body);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fwb-black);
    text-decoration: none;
    transition: all var(--fwb-transition);
    background: transparent;
    width: 100%;
    max-width: 320px;
  }
  .fwb-footer__pill:hover {
    background: var(--fwb-black);
    color: var(--fwb-white);
  }
  
  .fwb-footer__social { color: var(--fwb-black); margin-top: 1.5rem; display: inline-flex; justify-content: center; align-items: center; text-decoration: none; transition: opacity var(--fwb-transition); }
  .fwb-footer__social:hover { opacity: 0.7; }
  
  @media (max-width: 900px) {
    .fwb-footer__cols { grid-template-columns: 1fr; gap: 3rem; text-align: center; }
    .fwb-footer__col { align-items: center; text-align: center; }
    .fwb-footer__col--right { align-items: center; text-align: center; }
    .fwb-footer__pill { max-width: 100%; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "text", "id": "brand_name", "label": "Markenname (Footer)", "default": "FachWissenBau" },
    { "type": "link_list", "id": "menu", "label": "Footer Links", "default": "footer" },
    { "type": "image_picker", "id": "bg_image", "label": "Hintergrundbild (Stadtpanorama)" },
    {
      "type": "header",
      "content": "Kontakt"
    },
    { "type": "textarea", "id": "address", "label": "Adresse", "default": "FachWissenBau GmbH\nFlorastrasse 42\n8610 Uster" },
    { "type": "text", "id": "email", "label": "E-Mail", "default": "info@fachwissenbau.ch" },
    { "type": "url", "id": "linkedin_url", "label": "LinkedIn URL" }
  ]
}
{% endschema %}
