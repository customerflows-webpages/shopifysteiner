<footer class="fwb-footer">
  <div class="fwb-footer__bg">
    {%- if section.settings.bg_image != blank -%}
      <img src="{{ section.settings.bg_image | img_url: '1600x' }}" alt="" class="fwb-footer__bg-img" loading="lazy" aria-hidden="true">
    {%- else -%}
      <img src="{{ 'footer-cityscape.jpg' | asset_url }}" alt="" class="fwb-footer__bg-img" loading="lazy" aria-hidden="true">
    {%- endif -%}
    <div class="fwb-footer__overlay"></div>
  </div>

  <div class="fwb-footer__inner fwb-wrap">
    <div class="fwb-footer__brand">
      <p class="fwb-footer__shop-name">{{ shop.name }}</p>
    </div>
    <div class="fwb-footer__cols">
      <div class="fwb-footer__col">
        <p class="fwb-footer__col-text">Fachwissenbau GmbH<br>Florastrasse 42<br>8610 Uster</p>
      </div>
      <div class="fwb-footer__col">
        {% for link in section.settings.menu.links %}
          <a href="{{ link.url }}" class="fwb-footer__link">{{ link.title }}</a>
        {% endfor %}
      </div>
      <div class="fwb-footer__col fwb-footer__col--right">
        <a href="mailto:info@fachwissenbau.ch" class="fwb-footer__link">info@fachwissenbau.ch</a>
        <a href="https://www.linkedin.com/company/fachwissenbau" class="fwb-footer__social" target="_blank" rel="noopener" aria-label="LinkedIn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
      </div>
    </div>
  </div>
</footer>

{% stylesheet %}
  .fwb-footer { position: relative; overflow: hidden; }
  .fwb-footer__bg { position: absolute; inset: 0; z-index: 0; }
  .fwb-footer__bg-img { width: 100%; height: 100%; object-fit: cover; object-position: center 30%; filter: grayscale(100%); }
  .fwb-footer__overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.62); }
  .fwb-footer__inner { position: relative; z-index: 1; padding-top: 4rem; padding-bottom: 3rem; color: var(--fwb-white); }
  .fwb-footer__brand { text-align: center; margin-bottom: 3rem; padding-bottom: 2rem; border-bottom: 1px solid rgba(255,255,255,0.2); }
  .fwb-footer__shop-name { font-family: var(--fwb-font-heading); font-size: clamp(1.8rem,4vw,3rem); font-weight: 300; color: var(--fwb-white); }
  .fwb-footer__cols { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 2rem; align-items: start; }
  .fwb-footer__col { display: flex; flex-direction: column; gap: 0.5rem; }
  .fwb-footer__col--right { align-items: flex-end; text-align: right; }
  .fwb-footer__col-text { font-size: 0.8rem; line-height: 1.8; color: rgba(255,255,255,0.75); }
  .fwb-footer__link { font-size: 0.78rem; color: rgba(255,255,255,0.75); transition: color var(--fwb-transition); display: block; line-height: 2; }
  .fwb-footer__link:hover { color: var(--fwb-white); }
  .fwb-footer__social { color: rgba(255,255,255,0.75); margin-top: 0.5rem; display: inline-block; transition: color var(--fwb-transition); }
  .fwb-footer__social:hover { color: var(--fwb-white); }
  @media (max-width: 640px) { .fwb-footer__cols { grid-template-columns: 1fr; } .fwb-footer__col--right { align-items: flex-start; text-align: left; } }
{% endstylesheet %}

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "link_list", "id": "menu", "label": "Footer Links", "default": "footer" },
    { "type": "image_picker", "id": "bg_image", "label": "Hintergrundbild (Stadtpanorama)" }
  ]
}
{% endschema %}
