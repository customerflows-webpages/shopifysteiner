{% stylesheet %}

  .fwb-traeger {
    padding-block: var(--fwb-section-pad);
    background: var(--fwb-grey-100);
  }

  .fwb-traeger__header {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: clamp(2.5rem, 5vw, 5rem);
    max-width: 720px;
  }

  .fwb-traeger__title {
    font-style: italic;
  }

  .fwb-traeger__intro {
    font-size: 0.95rem;
    color: var(--fwb-grey-600);
    max-width: 600px;
  }

  .fwb-traeger__tier {
    margin-bottom: clamp(4rem, 6vw, 6rem);
  }

  .fwb-traeger__tier-label {
    width: 100%;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--fwb-grey-500);
    padding-top: 2rem;
    margin-bottom: 3rem;
    border-top: 1px solid var(--fwb-grey-200);
  }

  .fwb-traeger__header + .fwb-traeger__tier .fwb-traeger__tier-label {
    padding-top: 0;
    border-top: none;
  }

  .fwb-traeger__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    column-gap: clamp(3rem, 5vw, 5.5rem);
    row-gap: clamp(3.25rem, 5vw, 4.75rem);
    align-items: center;
  }

  .fwb-traeger__item {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 124px;
  }

  .fwb-traeger__link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: min(100%, 260px);
    height: 104px;
    line-height: 0;
    cursor: pointer;
  }

  .fwb-traeger__logo {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    mix-blend-mode: multiply;
    filter: grayscale(100%);
    opacity: 0.65;
    transition: filter 0.2s ease, opacity 0.2s ease;
  }

  .fwb-traeger__link:hover .fwb-traeger__logo {
    filter: grayscale(0%);
    opacity: 1;
  }

  @media (max-width: 989px) {
    .fwb-traeger__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      column-gap: clamp(2rem, 5vw, 3rem);
    }
  }

  @media (max-width: 749px) {
    .fwb-traeger__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      row-gap: 2.5rem;
    }

    .fwb-traeger__item {
      min-height: 104px;
    }

    .fwb-traeger__link {
      height: 86px;
      width: min(100%, 190px);
    }
  }

{% endstylesheet %}

{% schema %}
{
  "name": "Trägerschaft",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Trägerschaft"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Unsere Träger."
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Einleitungstext",
      "default": "FachWissenBau wird von einem breiten Kreis von Firmen aus der Schweizer Baubranche und Bildungsinstituten getragen. Ihr Engagement ermöglicht die Entstehung und Verbreitung von praxisnahem Fachwissen. Unserem Trägerschaftskreis danken wir ganz herzlich für die grosszügige Unterstützung – sowohl in fachlicher wie auch in finanzieller Hinsicht. Nur durch ihren Beitrag wurde die Entstehung dieser Fachbücher überhaupt erst ermöglicht."
    }
  ],
  "presets": [
    {
      "name": "Trägerschaft"
    }
  ]
}
{% endschema %}
