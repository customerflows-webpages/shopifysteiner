{% stylesheet %}

  .fwb-traeger {
    padding-block: var(--fwb-section-pad);
    background: var(--fwb-grey-100);
  }

  .fwb-traeger__header {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: clamp(3rem, 6vw, 6rem);
    max-width: 720px;
  }

  .fwb-traeger__title {
    font-style: italic;
  }

  .fwb-traeger__intro {
    font-size: 0.95rem;
    color: var(--fwb-grey-600);
    max-width: 600px;
  }

  .fwb-traeger__tier {
    margin-bottom: clamp(3rem, 6vw, 5rem);
  }

  .fwb-traeger__tier-label {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fwb-grey-500);
    padding-bottom: 1.25rem;
    margin-bottom: 2rem;
    border-bottom: 1px solid var(--fwb-grey-200);
  }

  .fwb-traeger__grid {
    display: flex;
    flex-wrap: wrap;
    gap: 2.75rem 4rem;
    align-items: center;
  }

  .fwb-traeger__item {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .fwb-traeger__link {
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 0;
    cursor: pointer;
  }

  .fwb-traeger__logo {
    object-fit: contain;
    width: 100%;
    height: 100%;
    filter: grayscale(100%);
    opacity: 0.65;
    transition: filter 0.2s ease, opacity 0.2s ease;
  }

  .fwb-traeger__grid--platin .fwb-traeger__link {
    height: 76px;
    width: auto;
  }

  .fwb-traeger__grid--platin .fwb-traeger__logo {
    width: auto;
    height: 76px;
    max-width: 280px;
    max-height: none;
  }

  .fwb-traeger__grid--gold .fwb-traeger__link {
    width: 170px;
    height: 74px;
  }

  .fwb-traeger__grid--gold .fwb-traeger__logo {
    width: auto;
    height: auto;
    max-width: 170px;
    max-height: 74px;
  }

  .fwb-traeger__grid--gold .fwb-traeger__link--gold-wide {
    width: 180px;
  }

  .fwb-traeger__grid--gold .fwb-traeger__link--gold-wide .fwb-traeger__logo {
    max-width: 180px;
  }

  .fwb-traeger__grid--gold .fwb-traeger__link--gold-extra-wide {
    width: 200px;
  }

  .fwb-traeger__grid--gold .fwb-traeger__link--gold-extra-wide .fwb-traeger__logo {
    max-width: 200px;
  }

  .fwb-traeger__grid--gold .fwb-traeger__link--gold-square {
    width: 86px;
    height: 86px;
  }

  .fwb-traeger__grid--gold .fwb-traeger__link--gold-square .fwb-traeger__logo {
    max-width: 86px;
    max-height: 86px;
  }

  .fwb-traeger__link:hover .fwb-traeger__logo {
    filter: grayscale(0%);
    opacity: 1;
  }

{% endstylesheet %}

{% schema %}
{
  "name": "Trägerschaft",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Trägerschaft"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Unsere Träger."
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Einleitungstext",
      "default": "FachWissenBau wird von einem breiten Kreis von Firmen aus der Schweizer Baubranche und Bildungsinstituten getragen. Ihr Engagement ermöglicht die Entstehung und Verbreitung von praxisnahem Fachwissen. Unserem Trägerschaftskreis danken wir ganz herzlich für die grosszügige Unterstützung – sowohl in fachlicher wie auch in finanzieller Hinsicht. Nur durch ihren Beitrag wurde die Entstehung dieser Fachbücher überhaupt erst ermöglicht."
    }
  ],
  "presets": [
    {
      "name": "Trägerschaft"
    }
  ]
}
{% endschema %}
