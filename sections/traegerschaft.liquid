{% stylesheet %}

  .fwb-traeger {
    padding-block: var(--fwb-section-pad);
    background: var(--fwb-grey-100);
  }

  .fwb-traeger__header {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: clamp(3rem, 6vw, 6rem);
    max-width: 720px;
  }

  .fwb-traeger__title {
    font-style: italic;
  }

  .fwb-traeger__intro {
    font-size: 0.95rem;
    color: var(--fwb-grey-600);
    max-width: 600px;
  }

  .fwb-traeger__tier {
    margin-bottom: clamp(3rem, 6vw, 5rem);
  }

  .fwb-traeger__tier-label {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fwb-grey-500);
    padding-bottom: 1.25rem;
    margin-bottom: 2rem;
    border-bottom: 1px solid var(--fwb-grey-200);
  }

  .fwb-traeger__grid {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
  }

  .fwb-traeger__grid--platin {
    gap: 2rem 4rem;
  }

  .fwb-traeger__grid--gold {
    gap: 1.75rem 3rem;
  }

  .fwb-traeger__item {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .fwb-traeger__link {
    display: block;
    line-height: 0;
  }

  .fwb-traeger__logo {
    object-fit: contain;
    filter: grayscale(100%);
    opacity: 0.6;
    transition: filter 0.2s ease, opacity 0.2s ease;
  }

  .fwb-traeger__grid--platin .fwb-traeger__logo {
    max-height: 80px;
    max-width: 240px;
    width: auto;
  }

  .fwb-traeger__grid--gold .fwb-traeger__logo {
    max-height: 56px;
    max-width: 180px;
    width: auto;
  }

  .fwb-traeger__link:hover .fwb-traeger__logo {
    filter: grayscale(0%);
    opacity: 1;
  }

  .fwb-traeger__item--text {
    min-height: 56px;
  }

  .fwb-traeger__grid--platin .fwb-traeger__item--text {
    min-height: 80px;
  }

  .fwb-traeger__name-link {
    font-family: var(--fwb-font-heading);
    font-weight: 300;
    letter-spacing: 0.03em;
    color: var(--fwb-grey-600);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .fwb-traeger__grid--platin .fwb-traeger__name-link {
    font-size: 1.05rem;
  }

  .fwb-traeger__grid--gold .fwb-traeger__name-link {
    font-size: 0.875rem;
  }

  .fwb-traeger__name-link:hover {
    color: var(--fwb-grey-900);
  }

  @media (max-width: 600px) {
    .fwb-traeger__grid--platin {
      gap: 1.75rem 2.5rem;
    }
    .fwb-traeger__grid--gold {
      gap: 1.5rem 2rem;
    }
    .fwb-traeger__grid--platin .fwb-traeger__logo {
      max-height: 60px;
      max-width: 180px;
    }
    .fwb-traeger__grid--gold .fwb-traeger__logo {
      max-height: 44px;
      max-width: 140px;
    }
  }

{% endstylesheet %}

{% schema %}
{
  "name": "Trägerschaft",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Trägerschaft"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Unsere Träger."
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Einleitungstext",
      "default": "FachWissenBau wird von einem breiten Kreis an Unternehmen und Organisationen aus der Schweizer Baubranche getragen. Ihr Engagement ermöglicht die Entstehung und Verbreitung von praxisnahem Fachwissen."
    }
  ],
  "presets": [
    {
      "name": "Trägerschaft"
    }
  ]
}
{% endschema %}
