<div class="fwb-authors">
  <div class="fwb-wrap">

    <div class="fwb-authors__header">
      <p class="fwb-label">{{ section.settings.label | default: 'Autoren' }}</p>
      <h2 class="fwb-h2 fwb-authors__title">{{ section.settings.heading }}</h2>
      {%- if section.settings.intro != blank -%}
        <p class="fwb-body fwb-authors__intro">{{ section.settings.intro }}</p>
      {%- endif -%}
    </div>

    <div class="fwb-authors__grid">
      {%- for block in section.blocks -%}
        <div class="fwb-authors__author" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <div class="fwb-authors__portrait">
              <img
                src="{{ block.settings.image | img_url: '400x' }}"
                alt="{{ block.settings.name }}"
                loading="lazy"
              >
            </div>
          {%- endif -%}
          <div class="fwb-authors__info">
            <h3 class="fwb-h3 fwb-authors__name">{{ block.settings.name }}</h3>
            {%- if block.settings.role != blank -%}
              <p class="fwb-label fwb-authors__role">{{ block.settings.role }}</p>
            {%- endif -%}
            {%- if block.settings.credentials != blank -%}
              <p class="fwb-body fwb-authors__credentials">{{ block.settings.credentials }}</p>
            {%- endif -%}
            {%- if block.settings.bio != blank -%}
              <p class="fwb-body fwb-authors__bio">{{ block.settings.bio }}</p>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>

    {%- if section.settings.cta_label != blank -%}
      <div class="fwb-authors__cta-wrap">
        <a href="{{ section.settings.cta_url | default: routes.cart_url }}" class="fwb-btn fwb-btn--solid">
          {{ section.settings.cta_label }}
        </a>
      </div>
    {%- endif -%}

    {%- if section.settings.tagline != blank -%}
      <p class="fwb-authors__tagline fwb-h2 fwb-text-center">{{ section.settings.tagline }}</p>
    {%- endif -%}

  </div>
</div>

{% stylesheet %}
  .fwb-authors {
    padding-block: var(--fwb-section-pad);
  }

  .fwb-authors__header {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: clamp(3rem, 6vw, 6rem);
  }

  .fwb-authors__title {
    font-style: italic;
  }

  .fwb-authors__intro {
    max-width: 680px;
    font-size: 0.9rem;
  }

  .fwb-authors__grid {
    display: flex;
    flex-direction: column;
    gap: clamp(3rem, 6vw, 6rem);
  }

  .fwb-authors__author {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: clamp(2rem, 5vw, 6rem);
    align-items: start;
    padding-bottom: clamp(3rem, 6vw, 6rem);
    border-bottom: 1px solid var(--fwb-grey-200);
  }

  .fwb-authors__author:last-child {
    border-bottom: none;
  }

  .fwb-authors__portrait img {
    width: 100%;
    aspect-ratio: 3/4;
    object-fit: cover;
    object-position: top;
    filter: grayscale(20%);
  }

  .fwb-authors__info {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding-top: 0.5rem;
  }

  .fwb-authors__name {
    font-size: 1.4rem;
  }

  .fwb-authors__credentials {
    font-size: 0.8rem;
    color: var(--fwb-grey-500);
    font-style: italic;
  }

  .fwb-authors__bio {
    font-size: 0.875rem;
    line-height: 1.8;
    max-width: 600px;
  }

  .fwb-authors__cta-wrap {
    text-align: center;
    margin-top: 3rem;
  }

  .fwb-authors__tagline {
    margin-top: 4rem;
    font-style: italic;
    color: var(--fwb-grey-500);
    font-size: clamp(1.2rem, 2.5vw, 2rem);
  }

  @media (max-width: 700px) {
    .fwb-authors__author {
      grid-template-columns: 1fr;
    }

    .fwb-authors__portrait img {
      aspect-ratio: 4/3;
      max-height: 320px;
      object-position: top center;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Autoren",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Autoren"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Praxis trifft Persönlichkeit."
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Einleitungstext"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button Text",
      "default": "Jetzt kaufen"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button Link"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Schlusszeile"
    }
  ],
  "blocks": [
    {
      "type": "author",
      "name": "Autor",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Portraitbild"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name"
        },
        {
          "type": "text",
          "id": "role",
          "label": "Funktion",
          "default": "Inhaber und Partner"
        },
        {
          "type": "text",
          "id": "credentials",
          "label": "Titel / Abschlüsse"
        },
        {
          "type": "textarea",
          "id": "bio",
          "label": "Biografie"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Autoren"
    }
  ]
}
{% endschema %}
