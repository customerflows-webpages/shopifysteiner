<header class="fwb-header" id="fwb-header">
  <div class="fwb-header__inner fwb-wrap">

    <a href="{{ routes.root_url }}" class="fwb-header__logo" aria-label="{{ shop.name }}">
      {%- if section.settings.logo != blank -%}
        <img
          src="{{ section.settings.logo | img_url: '300x' }}"
          alt="{{ section.settings.logo.alt | default: shop.name | escape }}"
          width="100"
          height="44"
          loading="eager"
        >
      {%- else -%}
        <img
          src="{{ 'logo.jpg' | asset_url }}"
          alt="{{ shop.name }}"
          width="100"
          height="44"
          loading="eager"
        >
      {%- endif -%}
    </a>

    <nav class="fwb-header__nav" id="fwb-nav" aria-label="Hauptnavigation">
      {%- assign hidden_links = 'Academy,Expertise,Kids' | split: ',' -%}
      {% for link in section.settings.menu.links %}
        {%- unless hidden_links contains link.title -%}
          {%- if link.title == 'Verlag' -%}
            {%- assign verlag_products = collections['verlag'].products -%}
            <div class="fwb-header__dropdown">
              <button class="fwb-header__nav-link fwb-header__dropdown-trigger" aria-expanded="false">
                {{ link.title }}
                <svg class="fwb-header__dropdown-arrow" width="10" height="6" viewBox="0 0 10 6" fill="none">
                  <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                </svg>
              </button>
              <div class="fwb-header__dropdown-menu">
                {%- if verlag_products.size > 0 -%}
                  {%- for product in verlag_products -%}
                    <a href="{{ product.url }}" class="fwb-header__dropdown-item">
                      <span class="fwb-header__dropdown-item-preview">
                        {%- if product.featured_image != blank -%}
                          <img src="{{ product.featured_image | img_url: '80x80', crop: 'center' }}" alt="{{ product.title | escape }}" width="40" height="40">
                        {%- endif -%}
                      </span>
                      <span class="fwb-header__dropdown-item-text">
                        <span class="fwb-header__dropdown-item-title">{{ product.title }}</span>
                        <span class="fwb-header__dropdown-item-price">ab {{ product.price_min | money }}</span>
                      </span>
                    </a>
                  {%- endfor -%}
                {%- else -%}
                  {%- assign all_products = collections.all.products -%}
                  {%- for product in all_products limit:4 -%}
                    <a href="{{ product.url }}" class="fwb-header__dropdown-item">
                      <span class="fwb-header__dropdown-item-preview">
                        {%- if product.featured_image != blank -%}
                          <img src="{{ product.featured_image | img_url: '80x80', crop: 'center' }}" alt="{{ product.title | escape }}" width="40" height="40">
                        {%- endif -%}
                      </span>
                      <span class="fwb-header__dropdown-item-text">
                        <span class="fwb-header__dropdown-item-title">{{ product.title }}</span>
                        <span class="fwb-header__dropdown-item-price">ab {{ product.price_min | money }}</span>
                      </span>
                    </a>
                  {%- endfor -%}
                {%- endif -%}
                <a href="{{ link.url }}" class="fwb-header__dropdown-all">Alle Bücher ansehen &rarr;</a>
              </div>
            </div>
          {%- elsif link.links.size > 0 -%}
            <div class="fwb-header__dropdown">
              <button class="fwb-header__nav-link fwb-header__dropdown-trigger" aria-expanded="false">
                {{ link.title }}
                <svg class="fwb-header__dropdown-arrow" width="10" height="6" viewBox="0 0 10 6" fill="none">
                  <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                </svg>
              </button>
              <div class="fwb-header__dropdown-menu">
                {%- for child in link.links -%}
                  <a href="{{ child.url }}" class="fwb-header__dropdown-item{% if child.active %} is-active{% endif %}">
                    {{ child.title }}
                  </a>
                {%- endfor -%}
              </div>
            </div>
          {%- else -%}
            <a
              href="{{ link.url }}"
              class="fwb-header__nav-link{% if link.active %} is-active{% endif %}"
            >{{ link.title }}</a>
          {%- endif -%}
        {%- endunless -%}
      {% endfor %}
    </nav>

    <div class="fwb-header__actions">
      <a href="{{ routes.cart_url }}" class="fwb-header__cart" aria-label="Warenkorb ({{ cart.item_count }})">
        {{ 'icon-cart.svg' | inline_asset_content }}
        {% if cart.item_count > 0 %}
          <span class="fwb-header__cart-count">{{ cart.item_count }}</span>
        {% endif %}
      </a>
      <button class="fwb-header__burger" id="fwb-burger" aria-label="Menü" aria-expanded="false">
        <span></span><span></span>
      </button>
    </div>

  </div>

  <!-- Mobile nav -->
  <div class="fwb-header__mobile-nav" id="fwb-mobile-nav" aria-hidden="true">
    {%- assign hidden_links = 'Academy,Expertise,Kids' | split: ',' -%}
    {% for link in section.settings.menu.links %}
      {%- unless hidden_links contains link.title -%}
        {%- if link.title == 'Verlag' -%}
          {%- assign verlag_products = collections['verlag'].products -%}
          <div class="fwb-header__mobile-group">
            <a href="{{ link.url }}" class="fwb-header__mobile-link fwb-header__mobile-parent">{{ link.title }}</a>
            {%- if verlag_products.size > 0 -%}
              {%- for product in verlag_products -%}
                <a href="{{ product.url }}" class="fwb-header__mobile-link fwb-header__mobile-child">{{ product.title }}</a>
              {%- endfor -%}
            {%- else -%}
              {%- for product in collections.all.products limit:4 -%}
                <a href="{{ product.url }}" class="fwb-header__mobile-link fwb-header__mobile-child">{{ product.title }}</a>
              {%- endfor -%}
            {%- endif -%}
          </div>
        {%- elsif link.links.size > 0 -%}
          <div class="fwb-header__mobile-group">
            <span class="fwb-header__mobile-link fwb-header__mobile-parent">{{ link.title }}</span>
            {%- for child in link.links -%}
              <a href="{{ child.url }}" class="fwb-header__mobile-link fwb-header__mobile-child">{{ child.title }}</a>
            {%- endfor -%}
          </div>
        {%- else -%}
          <a href="{{ link.url }}" class="fwb-header__mobile-link">{{ link.title }}</a>
        {%- endif -%}
      {%- endunless -%}
    {% endfor %}
  </div>
</header>

{% stylesheet %}
  .fwb-header {
    position: sticky;
    top: 0;
    z-index: 200;
    background: rgba(255,255,255,0.96);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--fwb-grey-200);
    transition: box-shadow 0.3s ease;
  }

  .fwb-header.is-scrolled {
    box-shadow: 0 1px 20px rgba(0,0,0,0.07);
  }

  .fwb-header__inner {
    display: flex;
    align-items: center;
    height: 68px;
    gap: 3rem;
  }

  .fwb-header__logo { flex-shrink: 0; }

  .fwb-header__logo img {
    height: 38px;
    width: auto;
    object-fit: contain;
    display: block;
  }

  .fwb-header__nav {
    display: flex;
    align-items: center;
    gap: clamp(1.2rem, 2.5vw, 2.5rem);
    flex: 1;
    justify-content: center;
  }

  .fwb-header__nav-link {
    font-family: var(--fwb-font-body);
    font-size: 0.78rem;
    font-weight: 400;
    letter-spacing: 0.04em;
    color: var(--fwb-grey-700);
    transition: color var(--fwb-transition);
    position: relative;
    padding-bottom: 1px;
    background: none;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0;
  }

  .fwb-header__nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--fwb-black);
    transform: scaleX(0);
    transition: transform 0.25s ease;
    transform-origin: left;
  }

  .fwb-header__nav-link:hover,
  .fwb-header__nav-link.is-active {
    color: var(--fwb-black);
  }

  .fwb-header__nav-link:hover::after,
  .fwb-header__nav-link.is-active::after {
    transform: scaleX(1);
  }

  /* ── Dropdown ── */
  .fwb-header__dropdown {
    position: relative;
  }

  .fwb-header__dropdown-arrow {
    transition: transform 0.2s ease;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .fwb-header__dropdown-trigger[aria-expanded="true"] .fwb-header__dropdown-arrow,
  .fwb-header__dropdown:hover .fwb-header__dropdown-arrow {
    transform: rotate(180deg);
  }

  .fwb-header__dropdown-menu {
    position: absolute;
    top: 100%;
    margin-top: 14px;
    left: 50%;
    transform: translateX(-50%);
    min-width: 240px;
    background: var(--fwb-white);
    border: 1px solid var(--fwb-grey-200);
    box-shadow: 0 8px 32px rgba(0,0,0,0.08);
    opacity: 0;
    pointer-events: none;
    transform: translateX(-50%) translateY(-6px);
    transition: opacity 0.2s ease, transform 0.2s ease;
    z-index: 300;
  }

  /* Add an invisible bridge so the hover state doesn't break when moving mouse from link to menu */
  .fwb-header__dropdown-menu::before {
    content: '';
    position: absolute;
    top: -14px;
    left: 0;
    right: 0;
    height: 14px;
  }

  .fwb-header__dropdown-menu.is-open,
  .fwb-header__dropdown:hover .fwb-header__dropdown-menu {
    opacity: 1;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }

  .fwb-header__dropdown-item {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.75rem 1.1rem;
    font-size: 0.78rem;
    letter-spacing: 0.03em;
    color: var(--fwb-grey-700);
    border-bottom: 1px solid var(--fwb-grey-100);
    transition: color var(--fwb-transition), background var(--fwb-transition);
    text-decoration: none;
    white-space: nowrap;
  }

  .fwb-header__dropdown-item:last-child {
    border-bottom: none;
  }

  .fwb-header__dropdown-item:hover,
  .fwb-header__dropdown-item.is-active {
    color: var(--fwb-black);
    background: var(--fwb-grey-100);
  }

  .fwb-header__dropdown-item-preview {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--fwb-grey-100);
  }

  .fwb-header__dropdown-item-preview img {
    width: 40px;
    height: 40px;
    object-fit: cover;
    filter: grayscale(100%);
    display: block;
  }

  .fwb-header__dropdown-item-text {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .fwb-header__dropdown-item-title {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--fwb-black);
    line-height: 1.2;
  }

  .fwb-header__dropdown-item-price {
    font-size: 0.7rem;
    color: var(--fwb-grey-500);
  }

  .fwb-header__dropdown-all {
    display: block;
    padding: 0.7rem 1.1rem;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--fwb-black);
    text-decoration: none;
    border-top: 1px solid var(--fwb-grey-200);
    background: var(--fwb-grey-100);
    transition: background var(--fwb-transition);
  }

  .fwb-header__dropdown-all:hover {
    background: var(--fwb-grey-200);
  }

  /* ── Actions ── */
  .fwb-header__actions {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    flex-shrink: 0;
  }

  .fwb-header__cart {
    display: flex;
    align-items: center;
    position: relative;
    color: var(--fwb-black);
    transition: opacity var(--fwb-transition);
  }

  .fwb-header__cart:hover { opacity: 0.6; }

  .fwb-header__cart svg {
    width: 20px;
    height: 20px;
  }

  .fwb-header__cart-count {
    font-size: 0.6rem;
    font-weight: 600;
    background: var(--fwb-black);
    color: var(--fwb-white);
    border-radius: 50%;
    width: 15px;
    height: 15px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: absolute;
    top: -5px;
    right: -7px;
  }

  .fwb-header__burger {
    display: none;
    flex-direction: column;
    gap: 6px;
    padding: 4px;
    background: none;
    border: none;
    cursor: pointer;
  }

  .fwb-header__burger span {
    display: block;
    width: 20px;
    height: 1px;
    background: var(--fwb-black);
    transition: transform 0.25s ease, opacity 0.25s ease;
  }

  .fwb-header__burger[aria-expanded="true"] span:first-child { transform: translateY(7px) rotate(45deg); }
  .fwb-header__burger[aria-expanded="true"] span:last-child  { transform: translateY(-7px) rotate(-45deg); }

  /* ── Mobile nav panel ── */
  .fwb-header__mobile-nav {
    display: none;
    flex-direction: column;
    background: var(--fwb-white);
    border-top: 1px solid var(--fwb-grey-200);
    overflow: hidden;
    max-height: 0;
    transition: max-height 0.35s ease;
  }

  .fwb-header__mobile-nav.is-open {
    max-height: 600px;
  }

  .fwb-header__mobile-link {
    display: block;
    padding: 0.9rem var(--fwb-gutter);
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    color: var(--fwb-grey-700);
    border-bottom: 1px solid var(--fwb-grey-100);
    transition: color var(--fwb-transition);
  }

  .fwb-header__mobile-link:hover { color: var(--fwb-black); }

  .fwb-header__mobile-parent {
    font-weight: 500;
    color: var(--fwb-grey-400);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding-top: 1.1rem;
    padding-bottom: 0.5rem;
  }

  .fwb-header__mobile-child {
    padding-left: calc(var(--fwb-gutter) + 0.75rem);
    font-size: 0.8rem;
    color: var(--fwb-grey-700);
  }

  @media (max-width: 860px) {
    .fwb-header__burger { display: flex; }
    .fwb-header__nav { display: none; }
    .fwb-header__mobile-nav { display: flex; }
    .fwb-header__inner { gap: 1rem; }
  }
{% endstylesheet %}

{% javascript %}
  const header = document.getElementById('fwb-header');
  const burger = document.getElementById('fwb-burger');
  const mobileNav = document.getElementById('fwb-mobile-nav');

  window.addEventListener('scroll', () => {
    header.classList.toggle('is-scrolled', window.scrollY > 10);
  }, { passive: true });

  burger.addEventListener('click', () => {
    const open = burger.getAttribute('aria-expanded') === 'true';
    burger.setAttribute('aria-expanded', String(!open));
    mobileNav.classList.toggle('is-open', !open);
    mobileNav.setAttribute('aria-hidden', String(open));
  });

  // Dropdowns
  document.querySelectorAll('.fwb-header__dropdown-trigger').forEach(trigger => {
    const menu = trigger.nextElementSibling;

    trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = trigger.getAttribute('aria-expanded') === 'true';
      // Close all others
      document.querySelectorAll('.fwb-header__dropdown-trigger').forEach(t => {
        t.setAttribute('aria-expanded', 'false');
        t.nextElementSibling.classList.remove('is-open');
      });
      if (!isOpen) {
        trigger.setAttribute('aria-expanded', 'true');
        menu.classList.add('is-open');
      }
    });
  });

  // Close on outside click
  document.addEventListener('click', () => {
    document.querySelectorAll('.fwb-header__dropdown-trigger').forEach(t => {
      t.setAttribute('aria-expanded', 'false');
      t.nextElementSibling.classList.remove('is-open');
    });
  });
{% endjavascript %}

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo" },
    { "type": "link_list", "id": "menu", "label": "Navigationsmenü", "default": "main-menu" }
  ]
}
{% endschema %}
