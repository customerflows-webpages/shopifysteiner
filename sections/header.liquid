<header class="fwb-header" id="fwb-header">
  <div class="fwb-header__inner fwb-wrap">

    <a href="{{ routes.root_url }}" class="fwb-header__logo" aria-label="{{ shop.name }}">
      <img
        src="{{ 'logo.jpg' | asset_url }}"
        alt="{{ shop.name }}"
        width="100"
        height="44"
        loading="eager"
      >
    </a>

    <nav class="fwb-header__nav" id="fwb-nav" aria-label="Hauptnavigation">
      {% for link in section.settings.menu.links %}
        <a
          href="{{ link.url }}"
          class="fwb-header__nav-link{% if link.active %} is-active{% endif %}"
        >{{ link.title }}</a>
      {% endfor %}
    </nav>

    <div class="fwb-header__actions">
      <a href="{{ routes.cart_url }}" class="fwb-header__cart" aria-label="Warenkorb ({{ cart.item_count }})">
        {{ 'icon-cart.svg' | inline_asset_content }}
        {% if cart.item_count > 0 %}
          <span class="fwb-header__cart-count">{{ cart.item_count }}</span>
        {% endif %}
      </a>
      <button class="fwb-header__burger" id="fwb-burger" aria-label="Menü" aria-expanded="false">
        <span></span><span></span>
      </button>
    </div>

  </div>

  <!-- Mobile nav -->
  <div class="fwb-header__mobile-nav" id="fwb-mobile-nav" aria-hidden="true">
    {% for link in section.settings.menu.links %}
      <a href="{{ link.url }}" class="fwb-header__mobile-link">{{ link.title }}</a>
    {% endfor %}
  </div>
</header>

{% stylesheet %}
  .fwb-header {
    position: sticky;
    top: 0;
    z-index: 200;
    background: rgba(255,255,255,0.96);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--fwb-grey-200);
    transition: box-shadow 0.3s ease;
  }

  .fwb-header.is-scrolled {
    box-shadow: 0 1px 20px rgba(0,0,0,0.07);
  }

  .fwb-header__inner {
    display: flex;
    align-items: center;
    height: 68px;
    gap: 3rem;
  }

  .fwb-header__logo {
    flex-shrink: 0;
  }

  .fwb-header__logo img {
    height: 38px;
    width: auto;
    object-fit: contain;
    display: block;
  }

  .fwb-header__nav {
    display: flex;
    align-items: center;
    gap: clamp(1.2rem, 2.5vw, 2.5rem);
    flex: 1;
    justify-content: center;
  }

  .fwb-header__nav-link {
    font-family: var(--fwb-font-body);
    font-size: 0.78rem;
    font-weight: 400;
    letter-spacing: 0.04em;
    color: var(--fwb-grey-700);
    transition: color var(--fwb-transition);
    position: relative;
    padding-bottom: 1px;
  }

  .fwb-header__nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--fwb-black);
    transform: scaleX(0);
    transition: transform 0.25s ease;
    transform-origin: left;
  }

  .fwb-header__nav-link:hover,
  .fwb-header__nav-link.is-active {
    color: var(--fwb-black);
  }

  .fwb-header__nav-link:hover::after,
  .fwb-header__nav-link.is-active::after {
    transform: scaleX(1);
  }

  .fwb-header__actions {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    flex-shrink: 0;
  }

  .fwb-header__cart {
    display: flex;
    align-items: center;
    position: relative;
    color: var(--fwb-black);
    transition: opacity var(--fwb-transition);
  }

  .fwb-header__cart:hover { opacity: 0.6; }

  .fwb-header__cart svg {
    width: 20px;
    height: 20px;
  }

  .fwb-header__cart-count {
    font-size: 0.6rem;
    font-weight: 600;
    background: var(--fwb-black);
    color: var(--fwb-white);
    border-radius: 50%;
    width: 15px;
    height: 15px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: absolute;
    top: -5px;
    right: -7px;
  }

  .fwb-header__burger {
    display: none;
    flex-direction: column;
    gap: 6px;
    padding: 4px;
    background: none;
    border: none;
    cursor: pointer;
  }

  .fwb-header__burger span {
    display: block;
    width: 20px;
    height: 1px;
    background: var(--fwb-black);
    transition: transform 0.25s ease, opacity 0.25s ease;
  }

  .fwb-header__burger[aria-expanded="true"] span:first-child { transform: translateY(7px) rotate(45deg); }
  .fwb-header__burger[aria-expanded="true"] span:last-child  { transform: translateY(-7px) rotate(-45deg); }

  /* Mobile nav panel */
  .fwb-header__mobile-nav {
    display: none;
    flex-direction: column;
    background: var(--fwb-white);
    border-top: 1px solid var(--fwb-grey-200);
    overflow: hidden;
    max-height: 0;
    transition: max-height 0.35s ease;
  }

  .fwb-header__mobile-nav.is-open {
    max-height: 400px;
  }

  .fwb-header__mobile-link {
    display: block;
    padding: 0.9rem var(--fwb-gutter);
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    color: var(--fwb-grey-700);
    border-bottom: 1px solid var(--fwb-grey-100);
    transition: color var(--fwb-transition);
  }

  .fwb-header__mobile-link:hover { color: var(--fwb-black); }

  @media (max-width: 860px) {
    .fwb-header__burger { display: flex; }
    .fwb-header__nav { display: none; }
    .fwb-header__mobile-nav { display: flex; }
    .fwb-header__inner { gap: 1rem; }
  }
{% endstylesheet %}

{% javascript %}
  const header = document.getElementById('fwb-header');
  const burger = document.getElementById('fwb-burger');
  const mobileNav = document.getElementById('fwb-mobile-nav');

  window.addEventListener('scroll', () => {
    header.classList.toggle('is-scrolled', window.scrollY > 10);
  }, { passive: true });

  burger.addEventListener('click', () => {
    const open = burger.getAttribute('aria-expanded') === 'true';
    burger.setAttribute('aria-expanded', String(!open));
    mobileNav.classList.toggle('is-open', !open);
    mobileNav.setAttribute('aria-hidden', String(open));
  });
{% endjavascript %}

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "link_list", "id": "menu", "label": "Navigationsmenü", "default": "main-menu" }
  ]
}
{% endschema %}
