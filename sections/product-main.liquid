<div class="fwb-product-notice">
  <div class="fwb-wrap fwb-product-notice__inner">
    <span class="fwb-product-notice__icon">&#9432;</span>
    <p>Für Auszubildende, Studierende, Dozierende und Buchhandlungen bieten wir spezielle Konditionen an. Bitte kontaktieren Sie uns vor der Bestellung über unser <a href="/pages/kontakt">Kontaktformular</a>.</p>
  </div>
</div>

<article class="fwb-product">
  <div class="fwb-wrap">

    <!-- Two-column: image LEFT, title + description + buy RIGHT -->
    <div class="fwb-product__main-row">

      <div class="fwb-product__image-col">
        {%- if product.featured_image != blank -%}
          <img
            src="{{ product.featured_image | img_url: '1000x' }}"
            alt="{{ product.featured_image.alt | default: product.title | escape }}"
            loading="eager"
            fetchpriority="high"
            class="fwb-product__hero-img"
          >
        {%- endif -%}
      </div>

      <div class="fwb-product__info-col">

        <!-- Title sits here now — no wasted full-width header -->
        <div class="fwb-product__title-block">
          <p class="fwb-label">{{ product.type | default: 'Fachbuch' }}</p>
          <h1 class="fwb-h1 fwb-product__title">{{ product.title }}</h1>
        </div>

        <!-- Accordion details -->
        <div class="fwb-product__accordions">
          {%- if section.blocks.size > 0 -%}
            {%- for block in section.blocks -%}
              <div class="fwb-product__accordion" {{ block.shopify_attributes }}>
                <button
                  class="fwb-product__accordion-trigger"
                  aria-expanded="false"
                  aria-controls="fwb-acc-body-{{ block.id }}"
                >
                  <span class="fwb-product__accordion-title">{{ block.settings.title }}</span>
                  <span class="fwb-product__accordion-icon" aria-hidden="true"></span>
                </button>
                <div
                  class="fwb-product__accordion-body"
                  id="fwb-acc-body-{{ block.id }}"
                >
                  <div class="fwb-product__accordion-inner">
                    {%- case block.type -%}
                      {%- when 'description' -%}
                        <div class="fwb-body fwb-product__acc-description">{{ product.description }}</div>
                      {%- when 'text' -%}
                        {%- if block.settings.content != blank -%}
                          <div class="fwb-body fwb-product__acc-text">{{ block.settings.content }}</div>
                        {%- endif -%}
                      {%- when 'specs' -%}
                        <dl class="fwb-product__specs">
                          {%- for i in (1..10) -%}
                            {%- assign lbl = 'spec_label_' | append: i -%}
                            {%- assign val = 'spec_value_' | append: i -%}
                            {%- if block.settings[lbl] != blank and block.settings[val] != blank -%}
                              <div class="fwb-product__spec-row">
                                <dt class="fwb-product__spec-label">{{ block.settings[lbl] }}</dt>
                                <dd class="fwb-product__spec-value">{{ block.settings[val] }}</dd>
                              </div>
                            {%- endif -%}
                          {%- endfor -%}
                        </dl>
                    {%- endcase -%}
                  </div>
                </div>
              </div>
            {%- endfor -%}
          {%- else -%}
            {%- comment -%} Fallback: no blocks set — show product description as single accordion {%- endcomment -%}
            <div class="fwb-product__accordion">
              <button class="fwb-product__accordion-trigger" aria-expanded="false" aria-controls="fwb-acc-body-default">
                <span class="fwb-product__accordion-title">{{ section.settings.desc_label | default: 'Beschreibung' }}</span>
                <span class="fwb-product__accordion-icon" aria-hidden="true"></span>
              </button>
              <div class="fwb-product__accordion-body" id="fwb-acc-body-default">
                <div class="fwb-product__accordion-inner">
                  <div class="fwb-body fwb-product__acc-description">{{ product.description }}</div>
                </div>
              </div>
            </div>
          {%- endif -%}
        </div>

        <!-- Buy / Variants -->
        <div class="fwb-product__buy" id="fwb-product-buy">
          <div class="fwb-product__variants-header">
            <p class="fwb-label">{{ section.settings.variants_label | default: 'Variationen' }}</p>
            <h3 class="fwb-h3 fwb-product__variants-title">{{ section.settings.variants_heading | default: 'Gedruckt. Digital. Oder beides.' }}</h3>
            {%- if section.settings.variants_body != blank -%}
              <p class="fwb-body fwb-product__variants-desc">{{ section.settings.variants_body }}</p>
            {%- endif -%}
          </div>

          {%- form 'product', product, id: 'fwb-product-form', novalidate: 'novalidate' -%}
            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

            {%- if product.has_only_default_variant == false -%}
              <div class="fwb-product__variant-list">
                {%- for variant in product.variants -%}
                  <label class="fwb-product__variant-option{% if variant == product.selected_or_first_available_variant %} is-selected{% endif %}{% unless variant.available %} is-unavailable{% endunless %}">
                    <input
                      type="radio"
                      name="variant"
                      value="{{ variant.id }}"
                      {% if variant == product.selected_or_first_available_variant %}checked{% endif %}
                      {% unless variant.available %}disabled{% endunless %}
                      data-variant-id="{{ variant.id }}"
                    >
                    <span class="fwb-product__variant-title">{{ variant.title }}</span>
                    <span class="fwb-product__variant-price">{{ variant.price | money }}</span>
                  </label>
                {%- endfor -%}
              </div>
            {%- else -%}
              <p class="fwb-product__single-price fwb-h3">{{ product.price | money }}</p>
            {%- endif -%}

            <button
              type="submit"
              name="add"
              class="fwb-btn fwb-btn--solid fwb-product__add-btn"
              {% unless product.available %}disabled{% endunless %}
            >
              {%- if product.available -%}
                {{ section.settings.buy_btn_label | default: 'Jetzt kaufen' }}
              {%- else -%}
                {{ section.settings.unavailable_label | default: 'Nicht verfügbar' }}
              {%- endif -%}
            </button>
          {%- endform -%}
        </div>

      </div>
    </div>

    <!-- Interior image carousel -->
    {%- if product.images.size > 1 -%}
      <div class="fwb-product__gallery-wrap">
        <p class="fwb-label fwb-product__gallery-label">{{ section.settings.gallery_label | default: 'Einblick' }}</p>
        <div class="fwb-product__gallery-track-wrap">
          <button class="fwb-product__gallery-btn" id="fwb-gallery-prev" aria-label="Zurück">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 18l-6-6 6-6"/></svg>
          </button>
          <div class="fwb-product__gallery-viewport">
            <div class="fwb-product__gallery-track" id="fwb-gallery-track">
              {%- for image in product.images offset: 1 -%}
                <div class="fwb-product__gallery-slide">
                  <img
                    src="{{ image | img_url: '900x' }}"
                    alt="{{ image.alt | default: product.title | escape }}"
                    loading="lazy"
                  >
                </div>
              {%- endfor -%}
            </div>
          </div>
          <button class="fwb-product__gallery-btn" id="fwb-gallery-next" aria-label="Weiter">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 18l6-6-6-6"/></svg>
          </button>
        </div>
      </div>
    {%- endif -%}

  </div>
</article>

{% stylesheet %}
  /* Notice banner */
  .fwb-product-notice {
    background: #f0f4e8;
    border-bottom: 1px solid #d4e0b8;
    padding: 0.75rem 0;
  }
  .fwb-product-notice__inner {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
  }
  .fwb-product-notice__icon {
    font-size: 1rem;
    line-height: 1.6;
    color: #5a7a2a;
    flex-shrink: 0;
  }
  .fwb-product-notice p {
    margin: 0;
    font-size: 0.875rem;
    line-height: 1.6;
    color: #3d3d3d;
  }
  .fwb-product-notice a {
    color: #5a7a2a;
    text-decoration: underline;
  }

  .fwb-product {
    padding-bottom: var(--fwb-section-pad);
  }

  /* Title block — lives inside the right column */
  .fwb-product__title-block {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding-bottom: clamp(1.5rem, 3vw, 2.5rem);
    border-bottom: 1px solid var(--fwb-grey-200);
  }

  .fwb-product__title {
    line-height: 1.1;
    letter-spacing: -0.01em;
  }

  /* Main two-column row — starts at top of page content */
  .fwb-product__main-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(3rem, 6vw, 8rem);
    align-items: start;
    padding-top: clamp(2.5rem, 5vw, 5rem);
    margin-bottom: clamp(4rem, 8vw, 8rem);
  }

  /* Left: image */
  .fwb-product__image-col {
    position: sticky;
    top: 90px;
  }

  .fwb-product__hero-img {
    width: 100%;
    aspect-ratio: 3/4;
    object-fit: cover;
    object-position: top;
    filter: grayscale(8%);
    display: block;
  }

  /* Right: description + buy */
  .fwb-product__info-col {
    display: flex;
    flex-direction: column;
    gap: clamp(2.5rem, 5vw, 4rem);
  }

  /* ── Accordions ── */
  .fwb-product__accordions {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--fwb-grey-200);
  }

  .fwb-product__accordion {
    border-bottom: 1px solid var(--fwb-grey-200);
  }

  .fwb-product__accordion-trigger {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.1rem 0;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    font-family: inherit;
    transition: color var(--fwb-transition);
  }

  .fwb-product__accordion-trigger:hover {
    color: var(--fwb-grey-700);
  }

  .fwb-product__accordion-title {
    font-family: var(--fwb-font-body);
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: inherit;
    flex: 1;
  }

  /* +/- icon */
  .fwb-product__accordion-icon {
    display: block;
    width: 14px;
    height: 14px;
    position: relative;
    flex-shrink: 0;
  }

  .fwb-product__accordion-icon::before,
  .fwb-product__accordion-icon::after {
    content: '';
    position: absolute;
    background: var(--fwb-black);
    transition: transform 0.25s ease, opacity 0.25s ease;
  }

  .fwb-product__accordion-icon::before {
    width: 14px; height: 1px;
    top: 50%; left: 0;
    transform: translateY(-50%);
  }

  .fwb-product__accordion-icon::after {
    width: 1px; height: 14px;
    top: 0; left: 50%;
    transform: translateX(-50%);
  }

  .fwb-product__accordion-trigger[aria-expanded="true"] .fwb-product__accordion-icon::after {
    transform: translateX(-50%) rotate(90deg);
    opacity: 0;
  }

  /* Panel */
  .fwb-product__accordion-body {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.3s ease;
  }

  .fwb-product__accordion-body.is-open {
    grid-template-rows: 1fr;
  }

  .fwb-product__accordion-inner {
    overflow: hidden;
  }

  .fwb-product__acc-description,
  .fwb-product__acc-text {
    font-size: 0.875rem;
    line-height: 1.85;
    color: var(--fwb-grey-700);
    padding-bottom: 1.25rem;
  }

  .fwb-product__acc-description p,
  .fwb-product__acc-text p {
    margin-bottom: 0.75em;
  }

  .fwb-product__acc-description p:last-child,
  .fwb-product__acc-text p:last-child {
    margin-bottom: 0;
  }

  .fwb-product__acc-description h3,
  .fwb-product__acc-text h3 {
    font-size: 0.85rem;
    font-weight: 500;
    margin-bottom: 0.5em;
    margin-top: 1em;
  }

  .fwb-product__acc-description ul,
  .fwb-product__acc-text ul {
    padding-left: 1.2em;
    display: flex;
    flex-direction: column;
    gap: 0.3em;
  }

  /* Specs table */
  .fwb-product__specs {
    display: flex;
    flex-direction: column;
    padding-bottom: 1.25rem;
  }

  .fwb-product__spec-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--fwb-grey-200);
    font-size: 0.82rem;
  }

  .fwb-product__spec-row:last-child {
    border-bottom: none;
  }

  .fwb-product__spec-label {
    color: var(--fwb-grey-500);
    flex-shrink: 0;
  }

  .fwb-product__spec-value {
    color: var(--fwb-text);
    text-align: right;
    font-weight: 500;
  }

  /* Buy block */
  .fwb-product__buy {
    background: var(--fwb-grey-100);
    padding: clamp(1.5rem, 4vw, 3rem);
  }

  .fwb-product__variants-header {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .fwb-product__variants-title {
    font-style: italic;
    font-weight: 300;
  }

  .fwb-product__variants-desc {
    font-size: 0.82rem;
    line-height: 1.7;
    color: var(--fwb-grey-600);
  }

  .fwb-product__variant-list {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-bottom: 1.5rem;
  }

  .fwb-product__variant-option {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.9rem 1.1rem;
    border: 1px solid var(--fwb-grey-300);
    background: var(--fwb-white);
    cursor: pointer;
    transition: border-color var(--fwb-transition);
  }

  .fwb-product__variant-option input[type="radio"] {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }

  .fwb-product__variant-option.is-selected {
    border-color: var(--fwb-black);
  }

  .fwb-product__variant-option.is-unavailable {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .fwb-product__variant-title {
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.03em;
  }

  .fwb-product__variant-price {
    font-size: 0.82rem;
    color: var(--fwb-grey-600);
  }

  .fwb-product__single-price {
    margin-bottom: 1.5rem;
  }

  .fwb-product__add-btn {
    width: 100%;
    padding: 1rem;
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-align: center;
    justify-content: center;
  }

  /* Gallery carousel */
  /* ── Gallery ── */
  .fwb-product__gallery-wrap {
    margin-bottom: clamp(3rem, 6vw, 6rem);
  }

  .fwb-product__gallery-label {
    margin-bottom: 1.25rem;
  }

  /* Outer row: arrows sit outside the viewport */
  .fwb-product__gallery-track-wrap {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  /* Viewport clips the track but also shows the peek on both sides */
  .fwb-product__gallery-viewport {
    flex: 1;
    overflow: hidden;
  }

  .fwb-product__gallery-track {
    display: flex;
    gap: 1rem;
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    /* Initial offset centres slide 0 — set by JS */
  }

  /* Each slide is 58% of the viewport width → ~21% peek on each side */
  .fwb-product__gallery-slide {
    min-width: 58%;
    flex-shrink: 0;
  }

  .fwb-product__gallery-slide img {
    width: 100%;
    height: 340px;
    object-fit: contain;
    background: var(--fwb-white);
    display: block;
  }

  .fwb-product__gallery-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    flex-shrink: 0;
    border: 1px solid var(--fwb-grey-300);
    background: transparent;
    cursor: pointer;
    color: var(--fwb-text);
    transition: border-color var(--fwb-transition), background var(--fwb-transition);
  }

  .fwb-product__gallery-btn:hover {
    border-color: var(--fwb-black);
    background: var(--fwb-black);
    color: var(--fwb-white);
  }

  .fwb-product__gallery-btn:disabled {
    opacity: 0.25;
    cursor: not-allowed;
  }

  @media (max-width: 860px) {
    .fwb-product__main-row {
      grid-template-columns: 1fr;
    }
    .fwb-product__image-col {
      position: static;
    }
    /* On mobile show one slide with visible neighbours */
    .fwb-product__gallery-slide {
      min-width: 78%;
    }
    .fwb-product__gallery-slide img {
      height: 220px;
      object-fit: contain;
      background: var(--fwb-white);
    }
  }
{% endstylesheet %}

<script>
  document.addEventListener('DOMContentLoaded', function () {

    // ── Accordions ──────────────────────────────────────────────────
    document.querySelectorAll('.fwb-product__accordion-trigger').forEach(function (trigger) {
      trigger.addEventListener('click', function () {
        var isOpen = trigger.getAttribute('aria-expanded') === 'true';
        var body   = document.getElementById(trigger.getAttribute('aria-controls'));
        trigger.setAttribute('aria-expanded', String(!isOpen));
        if (body) body.classList.toggle('is-open', !isOpen);
      });
    });

    // ── Variant selector ────────────────────────────────────────────
    var variantOptions = document.querySelectorAll('.fwb-product__variant-option');
    var hiddenInput    = document.querySelector('#fwb-product-form input[name="id"]');

    variantOptions.forEach(function (option) {
      option.addEventListener('click', function () {
        var radio = option.querySelector('input[type="radio"]');
        if (radio.disabled) return;
        variantOptions.forEach(function (o) { o.classList.remove('is-selected'); });
        option.classList.add('is-selected');
        radio.checked = true;
        if (hiddenInput) hiddenInput.value = radio.dataset.variantId;
      });
    });

    // ── Gallery carousel — centred peek layout ───────────────────────
    (function () {
      var track = document.getElementById('fwb-gallery-track');
      if (!track) return;

      var prevBtn  = document.getElementById('fwb-gallery-prev');
      var nextBtn  = document.getElementById('fwb-gallery-next');
      var viewport = track.parentElement;
      var slides   = Array.from(track.querySelectorAll('.fwb-product__gallery-slide'));
      var GAP      = 16;
      var current  = 0;

      function slideWidth() {
        return slides[0] ? slides[0].offsetWidth : 0;
      }

      function offsetForIndex(i) {
        var sw     = slideWidth();
        var vw     = viewport.offsetWidth;
        var base   = i * (sw + GAP);
        var centre = base - (vw - sw) / 2;
        return Math.max(0, centre);
      }

      function update() {
        track.style.transform = 'translateX(-' + offsetForIndex(current) + 'px)';
        if (prevBtn) prevBtn.disabled = current === 0;
        if (nextBtn) nextBtn.disabled = current === slides.length - 1;
      }

      if (prevBtn) prevBtn.addEventListener('click', function () { if (current > 0) { current--; update(); } });
      if (nextBtn) nextBtn.addEventListener('click', function () { if (current < slides.length - 1) { current++; update(); } });

      window.addEventListener('resize', update, { passive: true });
      update();
    })();

  });
</script>

{% schema %}
{
  "name": "Produkt Hauptbereich",
  "settings": [
    { "type": "text", "id": "desc_label", "label": "Fallback Accordion Titel", "default": "Beschreibung" },
    { "type": "text", "id": "variants_label", "label": "Variationen Label", "default": "Variationen" },
    { "type": "text", "id": "variants_heading", "label": "Variationen Überschrift", "default": "Gedruckt. Digital. Oder beides." },
    { "type": "textarea", "id": "variants_body", "label": "Variationen Text", "default": "Das Fachbuch ist als hochwertiger Hardcover-Band, als digitale Version via Edubase-Reader oder im Kombiangebot erhältlich." },
    { "type": "text", "id": "gallery_label", "label": "Einblick Label", "default": "Einblick" },
    { "type": "text", "id": "buy_btn_label", "label": "Kaufen Button Text", "default": "Jetzt kaufen" },
    { "type": "text", "id": "unavailable_label", "label": "Nicht verfügbar Text", "default": "Nicht verfügbar" }
  ],
  "blocks": [
    {
      "type": "description",
      "name": "Buchbeschreibung",
      "settings": [
        { "type": "text", "id": "title", "label": "Accordion Titel", "default": "Beschreibung" }
      ]
    },
    {
      "type": "text",
      "name": "Textblock",
      "settings": [
        { "type": "text", "id": "title", "label": "Accordion Titel", "default": "Details" },
        { "type": "richtext", "id": "content", "label": "Inhalt" }
      ]
    },
    {
      "type": "specs",
      "name": "Buchdetails",
      "settings": [
        { "type": "text", "id": "title", "label": "Accordion Titel", "default": "Buchdetails" },
        { "type": "text", "id": "spec_label_1", "label": "Feld 1 – Bezeichnung", "default": "Seiten" },
        { "type": "text", "id": "spec_value_1", "label": "Feld 1 – Wert" },
        { "type": "text", "id": "spec_label_2", "label": "Feld 2 – Bezeichnung", "default": "Format" },
        { "type": "text", "id": "spec_value_2", "label": "Feld 2 – Wert" },
        { "type": "text", "id": "spec_label_3", "label": "Feld 3 – Bezeichnung", "default": "Einband" },
        { "type": "text", "id": "spec_value_3", "label": "Feld 3 – Wert", "default": "Hardcover" },
        { "type": "text", "id": "spec_label_4", "label": "Feld 4 – Bezeichnung", "default": "Sprache" },
        { "type": "text", "id": "spec_value_4", "label": "Feld 4 – Wert", "default": "Deutsch" },
        { "type": "text", "id": "spec_label_5", "label": "Feld 5 – Bezeichnung", "default": "Verlag" },
        { "type": "text", "id": "spec_value_5", "label": "Feld 5 – Wert", "default": "FachWissenBau" },
        { "type": "text", "id": "spec_label_6", "label": "Feld 6 – Bezeichnung" },
        { "type": "text", "id": "spec_value_6", "label": "Feld 6 – Wert" },
        { "type": "text", "id": "spec_label_7", "label": "Feld 7 – Bezeichnung" },
        { "type": "text", "id": "spec_value_7", "label": "Feld 7 – Wert" },
