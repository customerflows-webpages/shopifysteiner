<div class="fwb-kids">
  <div class="fwb-wrap">
    <div class="fwb-kids__title-block">
      <p class="fwb-label">FWB Kids</p>
      <h1 class="fwb-display fwb-kids__title">{{ section.settings.heading | default: 'FWB Kids – Mit Spass auf die Baustelle' }}</h1>
    </div>
  </div>

  <div class="fwb-wrap fwb-kids__intro-row">
    <div class="fwb-kids__characters">
      {%- if section.settings.characters_image != blank -%}
        <img src="{{ section.settings.characters_image | img_url: '900x' }}" alt="Tres Bau Amigos" loading="lazy">
      {%- else -%}
        <img src="{{ 'kids-characters.jpg' | asset_url }}" alt="Tres Bau Amigos" loading="lazy">
      {%- endif -%}
    </div>
    <div class="fwb-kids__intro-text">
      <p class="fwb-body">{{ section.settings.body_1 }}</p>
    </div>
  </div>

  <div class="fwb-wrap fwb-kids__second-row">
    <div class="fwb-kids__second-text">
      <p class="fwb-body">{{ section.settings.body_2 }}</p>
    </div>
    <div class="fwb-kids__dumper">
      {%- if section.settings.dumper_image != blank -%}
        <img src="{{ section.settings.dumper_image | img_url: '700x' }}" alt="Dumper" loading="lazy">
      {%- else -%}
        <img src="{{ 'kids-dumper.jpg' | asset_url }}" alt="Dumper" loading="lazy">
      {%- endif -%}
    </div>
  </div>

  <div class="fwb-kids__repeat-section">
    <div class="fwb-wrap">
      <h2 class="fwb-h1 fwb-kids__repeat-title fwb-text-center">{{ section.settings.heading | default: 'FWB Kids – Mit Spass auf die Baustelle' }}</h2>
      <p class="fwb-body fwb-kids__repeat-body fwb-text-center">{{ section.settings.body_2 }}</p>
    </div>
  </div>

  <div class="fwb-wrap fwb-kids__logo-wrap">
    {%- if section.settings.kids_logo != blank -%}
      <img src="{{ section.settings.kids_logo | img_url: '400x' }}" alt="FWB Kids Logo" loading="lazy" class="fwb-kids__logo">
    {%- else -%}
      <img src="{{ 'kids-logo.jpg' | asset_url }}" alt="FWB Kids Logo" loading="lazy" class="fwb-kids__logo">
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .fwb-kids { padding-bottom: var(--fwb-section-pad); overflow: hidden; }
  .fwb-kids__title-block { padding-block: clamp(4rem,8vw,9rem); display: flex; flex-direction: column; gap: 1.25rem; border-bottom: 1px solid var(--fwb-grey-200); margin-bottom: clamp(4rem,8vw,7rem); max-width: 860px; }
  .fwb-kids__title { font-weight: 300; }
  .fwb-kids__intro-row { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(3rem,6vw,8rem); align-items: center; margin-bottom: clamp(5rem,10vw,10rem); }
  .fwb-kids__characters img { width: 100%; object-fit: contain; max-height: 500px; }
  .fwb-kids__intro-text .fwb-body { font-size: clamp(0.9rem,1.1vw,1rem); line-height: 1.85; }
  .fwb-kids__second-row { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(3rem,6vw,8rem); align-items: center; margin-bottom: clamp(5rem,10vw,10rem); }
  .fwb-kids__second-text .fwb-body { font-size: clamp(0.9rem,1.1vw,1rem); line-height: 1.85; }
  .fwb-kids__dumper img { width: 100%; object-fit: contain; max-height: 400px; }
  .fwb-kids__repeat-section { background: var(--fwb-grey-100); padding-block: clamp(4rem,8vw,8rem); margin-bottom: clamp(4rem,8vw,7rem); }
  .fwb-kids__repeat-title { font-style: italic; margin-bottom: 2rem; font-weight: 300; }
  .fwb-kids__repeat-body { max-width: 680px; margin-inline: auto; font-size: clamp(0.9rem,1.1vw,1rem); line-height: 1.85; }
  .fwb-kids__logo-wrap { display: flex; justify-content: flex-end; padding-bottom: 3rem; }
  .fwb-kids__logo { width: clamp(140px,20vw,220px); object-fit: contain; }
  @media (max-width: 768px) { .fwb-kids__intro-row, .fwb-kids__second-row { grid-template-columns: 1fr; } }
{% endstylesheet %}

{% schema %}
{
  "name": "Kids Seite",
  "settings": [
    { "type": "text", "id": "heading", "label": "Überschrift", "default": "FWB Kids – Mit Spass auf die Baustelle" },
    { "type": "image_picker", "id": "characters_image", "label": "Bild Charaktere" },
    { "type": "textarea", "id": "body_1", "label": "Text 1", "default": "Mit FWB Kids bringen wir die Faszination des Bauens direkt ins Klassenzimmer. Eine erfahrene Fachperson aus der Bauwelt besucht gemeinsam mit einer Lehrperson Schulklassen – und vermittelt kindgerecht, was Bauen eigentlich bedeutet. Spielerisch, anschaulich und mit jeder Menge Begeisterung zeigen wir, wie spannend und wichtig Berufe rund um die Baustelle sind." },
    { "type": "image_picker", "id": "dumper_image", "label": "Bild Baumaschine" },
    { "type": "textarea", "id": "body_2", "label": "Text 2", "default": "Mit FWB Kids bringen wir die Faszination des Bauens direkt ins Klassenzimmer. Eine erfahrene Fachperson aus der Bauwelt besucht gemeinsam mit einer Lehrperson Schulklassen – und vermittelt kindgerecht, was Bauen eigentlich bedeutet. Spielerisch, anschaulich und mit jeder Menge Begeisterung zeigen wir, wie spannend und wichtig Berufe rund um die Baustelle sind." },
    { "type": "image_picker", "id": "kids_logo", "label": "FWB Kids Logo" }
  ],
  "presets": [{ "name": "Kids Seite" }]
}
{% endschema %}
