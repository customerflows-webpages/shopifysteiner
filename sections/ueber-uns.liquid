<div class="fwb-ueber-uns">
  <div class="fwb-wrap">

    <!-- Title row -->
    <div class="fwb-ueber-uns__title-row">
      <div class="fwb-ueber-uns__title-text">
        {%- if section.settings.label != blank -%}
          <p class="fwb-label">{{ section.settings.label }}</p>
        {%- endif -%}
        <h1 class="fwb-display fwb-ueber-uns__title">{{ section.settings.heading | default: 'Grüezi, wir bauen Zukunft.' }}</h1>
        <div class="fwb-ueber-uns__intro-body">
          {%- if section.settings.lead != blank -%}
            <p class="fwb-ueber-uns__lead">{{ section.settings.lead }}</p>
          {%- endif -%}
          {%- if section.settings.body != blank -%}
            <div class="fwb-ueber-uns__body fwb-body">{{ section.settings.body | newline_to_br }}</div>
          {%- endif -%}
        </div>
      </div>
      <div class="fwb-ueber-uns__title-images">
        {%- if section.settings.image_1 != blank -%}
          <img src="{{ section.settings.image_1 | img_url: '900x' }}" alt="" loading="lazy" class="fwb-ueber-uns__img-top">
        {%- else -%}
          <img src="{{ 'ueber-uns-1.jpg' | asset_url }}" alt="" loading="lazy" class="fwb-ueber-uns__img-top">
        {%- endif -%}
        {%- if section.settings.image_2 != blank -%}
          <img src="{{ section.settings.image_2 | img_url: '900x' }}" alt="" loading="lazy" class="fwb-ueber-uns__img-bottom">
        {%- else -%}
          <img src="{{ 'ueber-uns-2.jpg' | asset_url }}" alt="" loading="lazy" class="fwb-ueber-uns__img-bottom">
        {%- endif -%}
      </div>
    </div>

    <!-- Authors intro -->
    <div class="fwb-ueber-uns__autoren-header">
      <div class="fwb-ueber-uns__autoren-text">
        {%- if section.settings.authors_heading != blank -%}
          <h2 class="fwb-h2 fwb-ueber-uns__autoren-heading">{{ section.settings.authors_heading }}</h2>
        {%- endif -%}
        {%- if section.settings.authors_intro != blank -%}
          <div class="fwb-body">{{ section.settings.authors_intro | newline_to_br }}</div>
        {%- endif -%}
      </div>
    </div>

    <!-- Authors: individual portrait + accordion for each -->
    <div class="fwb-ueber-uns__authors-grid">
      {%- assign fallbacks = 'author-rolf-steiner.jpg,author-tobias-frick.jpg' | split: ',' -%}
      {%- for block in section.blocks -%}
        <div class="fwb-ueber-uns__author-card" {{ block.shopify_attributes }}>

          <!-- Portrait -->
          <div class="fwb-ueber-uns__author-portrait">
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | img_url: '800x' }}" alt="{{ block.settings.name | escape }}" loading="lazy">
            {%- else -%}
              <img src="{{ fallbacks[forloop.index0] | asset_url }}" alt="{{ block.settings.name | escape }}" loading="lazy">
            {%- endif -%}
          </div>

          <!-- Info + accordion -->
          <div class="fwb-ueber-uns__author-info">
            <div class="fwb-ueber-uns__author-row-header">
              <h3 class="fwb-ueber-uns__author-name">{{ block.settings.name }}</h3>
              <button class="fwb-ueber-uns__toggle" aria-expanded="false" aria-label="Details anzeigen">
                <span class="fwb-ueber-uns__toggle-icon"></span>
              </button>
            </div>
            <div class="fwb-ueber-uns__author-detail">
              {%- if block.settings.role != blank -%}
                <p class="fwb-label fwb-ueber-uns__author-role">{{ block.settings.role }}</p>
              {%- endif -%}
              {%- if block.settings.credentials != blank -%}
                <div class="fwb-body fwb-ueber-uns__author-creds">{{ block.settings.credentials | newline_to_br }}</div>
              {%- endif -%}
              {%- if block.settings.bio != blank -%}
                <p class="fwb-body fwb-ueber-uns__author-bio">{{ block.settings.bio }}</p>
              {%- endif -%}
            </div>
          </div>

        </div>
      {%- endfor -%}
    </div>

  </div>
</div>

{% stylesheet %}
  .fwb-ueber-uns { padding-bottom: var(--fwb-section-pad); }

  /* ── Title row ── */
  .fwb-ueber-uns__title-row {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: clamp(4rem, 8vw, 10rem);
    align-items: start;
    padding-block: clamp(4rem, 8vw, 9rem);
    border-bottom: 1px solid var(--fwb-grey-200);
    margin-bottom: clamp(4rem, 8vw, 8rem);
  }

  .fwb-ueber-uns__title-text {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .fwb-ueber-uns__title { font-weight: 300; }

  .fwb-ueber-uns__intro-body {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    max-width: 500px;
  }

  .fwb-ueber-uns__lead {
    font-family: var(--fwb-font-heading);
    font-size: clamp(1.05rem, 1.6vw, 1.35rem);
    font-weight: 300;
    font-style: italic;
    line-height: 1.55;
    color: var(--fwb-black);
  }

  .fwb-ueber-uns__title-images {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .fwb-ueber-uns__img-top {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    filter: grayscale(100%);
  }

  .fwb-ueber-uns__img-bottom {
    width: 100%;
    aspect-ratio: 16/9;
    object-fit: cover;
    filter: grayscale(100%);
  }

  /* ── Authors intro ── */
  .fwb-ueber-uns__autoren-header {
    max-width: 760px;
    margin-bottom: clamp(4rem, 8vw, 8rem);
    padding-bottom: clamp(4rem, 8vw, 8rem);
    border-bottom: 1px solid var(--fwb-grey-200);
  }

  .fwb-ueber-uns__autoren-text {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .fwb-ueber-uns__autoren-heading {
    font-style: italic;
    font-weight: 300;
  }

  /* ── Authors grid: each card = portrait + accordion ── */
  .fwb-ueber-uns__authors-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 380px));
    gap: clamp(2rem, 4vw, 5rem);
    justify-content: center;
  }

  .fwb-ueber-uns__author-card {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .fwb-ueber-uns__author-portrait {
    margin-bottom: 0;
    overflow: hidden;
  }

  .fwb-ueber-uns__author-portrait img {
    width: 100%;
    aspect-ratio: 3/4;
    object-fit: cover;
    object-position: top;
    filter: grayscale(10%);
    display: block;
  }

  .fwb-ueber-uns__author-info {
    border-top: 1px solid var(--fwb-grey-200);
    border-bottom: 1px solid var(--fwb-grey-200);
  }

  .fwb-ueber-uns__author-row-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 0;
    cursor: pointer;
  }

  .fwb-ueber-uns__author-name {
    font-family: var(--fwb-font-heading);
    font-size: clamp(1.1rem, 1.8vw, 1.4rem);
    font-weight: 300;
    color: var(--fwb-black);
  }

  .fwb-ueber-uns__toggle {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .fwb-ueber-uns__toggle-icon {
    display: block;
    width: 16px;
    height: 16px;
    position: relative;
  }

  .fwb-ueber-uns__toggle-icon::before,
  .fwb-ueber-uns__toggle-icon::after {
    content: '';
    position: absolute;
    background: var(--fwb-black);
    border-radius: 1px;
    transition: transform 0.25s ease, opacity 0.25s ease;
  }

  .fwb-ueber-uns__toggle-icon::before {
    width: 16px; height: 1px;
    top: 50%; left: 0;
    transform: translateY(-50%);
  }

  .fwb-ueber-uns__toggle-icon::after {
    width: 1px; height: 16px;
    top: 0; left: 50%;
    transform: translateX(-50%);
  }

  .fwb-ueber-uns__toggle[aria-expanded="true"] .fwb-ueber-uns__toggle-icon::after {
    transform: translateX(-50%) rotate(90deg);
    opacity: 0;
  }

  .fwb-ueber-uns__author-detail {
    display: none;
    flex-direction: column;
    gap: 0.75rem;
    padding-bottom: 1.5rem;
  }

  .fwb-ueber-uns__author-detail.is-open {
    display: flex;
  }

  .fwb-ueber-uns__author-role {
    color: var(--fwb-grey-500);
  }

  .fwb-ueber-uns__author-creds {
    font-style: italic;
    color: var(--fwb-grey-700);
    font-size: 0.88rem;
  }

  .fwb-ueber-uns__author-bio {
    font-size: 0.88rem;
    line-height: 1.8;
    color: var(--fwb-grey-700);
  }

  @media (max-width: 900px) {
    .fwb-ueber-uns__authors-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 768px) {
    .fwb-ueber-uns__title-row { grid-template-columns: 1fr; }
  }
{% endstylesheet %}

{% javascript %}
  document.querySelectorAll('.fwb-ueber-uns__author-row-header').forEach(header => {
    header.addEventListener('click', () => {
      const card = header.closest('.fwb-ueber-uns__author-card');
      const detail = card.querySelector('.fwb-ueber-uns__author-detail');
      const toggle = card.querySelector('.fwb-ueber-uns__toggle');
      const isOpen = detail.classList.toggle('is-open');
      toggle.setAttribute('aria-expanded', String(isOpen));
    });
  });

  // Open all authors by default
  document.querySelectorAll('.fwb-ueber-uns__author-detail').forEach((detail, i) => {
    detail.classList.add('is-open');
    detail.closest('.fwb-ueber-uns__author-card')
      .querySelector('.fwb-ueber-uns__toggle')
      .setAttribute('aria-expanded', 'true');
  });
{% endjavascript %}

{% schema %}
{
  "name": "Über uns Seite",
  "settings": [
    { "type": "text", "id": "heading", "label": "Hauptüberschrift", "default": "Grüezi, wir bauen Zukunft." },
    { "type": "text", "id": "label", "label": "Label", "default": "Über uns" },
    { "type": "textarea", "id": "lead", "label": "Lead Text", "default": "FachWissenBau ist das Kompetenznetzwerk für die Schweizer Bauwirtschaft." },
    { "type": "textarea", "id": "body", "label": "Fliesstext", "default": "Als Verlag gegründet, entwickeln wir heute ein umfassendes Ökosystem aus Fachpublikationen, Weiterbildung, Beratung und Vernetzung." },
    { "type": "image_picker", "id": "image_1", "label": "Bild oben rechts" },
    { "type": "image_picker", "id": "image_2", "label": "Bild unten rechts" },
    { "type": "header", "content": "Autoren Bereich" },
    { "type": "text", "id": "authors_heading", "label": "Autoren Überschrift", "default": "Die Autoren" },
    { "type": "textarea", "id": "authors_intro", "label": "Autoren Einleitungstext", "default": "Die beiden Autoren – Rolf Steiner und Tobias Frick – vereinen über 50 Jahre Praxiserfahrung in der Planung und Ausführung von Infrastrukturprojekten – in der Schweiz wie auch im Ausland." }
  ],
  "blocks": [
    {
      "type": "founder",
      "name": "Autor",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Portraitbild" },
        { "type": "text", "id": "name", "label": "Name" },
        { "type": "text", "id": "role", "label": "Funktion", "default": "Inhaber und Partner" },
        { "type": "textarea", "id": "credentials", "label": "Titel / Abschlüsse" },
        { "type": "textarea", "id": "bio", "label": "Biografie" }
      ]
    }
  ],
  "presets": [{ "name": "Über uns Seite" }]
}
{% endschema %}
