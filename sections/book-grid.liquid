<div class="fwb-book-grid" style="background: {{ section.settings.bg_color }};">
  <div class="fwb-wrap">

    {%- if section.settings.heading != blank -%}
      <h2 class="fwb-display fwb-book-grid__heading fwb-text-center">
        {{ section.settings.heading }}
      </h2>
    {%- endif -%}

    {%- if section.settings.collection != blank -%}
      {%- assign books = section.settings.collection.products -%}
    {%- else -%}
      {%- assign books = collections.all.products | limit: 4 -%}
    {%- endif -%}

    <div class="fwb-book-grid__books">
      {%- for book in books limit: 4 -%}
        <div class="fwb-book-grid__item">
          <a href="{{ book.url }}" class="fwb-book-grid__image-link">
            {%- if book.featured_image != blank -%}
              <img
                src="{{ book.featured_image | img_url: '600x' }}"
                alt="{{ book.featured_image.alt | default: book.title | escape }}"
                loading="lazy"
              >
            {%- endif -%}
          </a>
          <div class="fwb-book-grid__info">
            <h3 class="fwb-h3 fwb-book-grid__title">{{ book.title }}</h3>
            <p class="fwb-book-grid__excerpt fwb-body">{{ book.description | strip_html | truncate: 120 }}</p>
            <a href="{{ book.url }}" class="fwb-btn fwb-book-grid__cta">Mehr erfahren</a>
          </div>
        </div>
      {%- endfor -%}
    </div>

  </div>
</div>

{% stylesheet %}
  .fwb-book-grid {
    padding-block: var(--fwb-section-pad);
  }

  .fwb-book-grid__heading {
    margin-bottom: clamp(2.5rem, 5vw, 5rem);
    font-style: italic;
  }

  .fwb-book-grid__books {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(1.5rem, 3vw, 3rem);
    align-items: start;
  }

  .fwb-book-grid__item {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .fwb-book-grid__image-link {
    display: block;
    overflow: hidden;
  }

  .fwb-book-grid__image-link img {
    width: 100%;
    aspect-ratio: 3/4;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .fwb-book-grid__image-link:hover img {
    transform: scale(1.02);
  }

  .fwb-book-grid__info {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .fwb-book-grid__title {
    font-size: clamp(0.95rem, 1.2vw, 1.15rem);
  }

  .fwb-book-grid__excerpt {
    font-size: 0.8rem;
    line-height: 1.6;
    color: var(--fwb-grey-500);
  }

  .fwb-book-grid__cta {
    align-self: flex-start;
    margin-top: 0.25rem;
    font-size: 0.68rem;
    padding: 0.5rem 1.25rem;
  }

  @media (max-width: 900px) {
    .fwb-book-grid__books {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 540px) {
    .fwb-book-grid__books {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Büchergitter",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Hintergrundfarbe",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Bereit zum Blättern."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Kollektion"
    }
  ],
  "presets": [
    {
      "name": "Büchergitter"
    }
  ]
}
{% endschema %}
