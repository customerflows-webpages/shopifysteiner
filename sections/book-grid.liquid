<div class="fwb-book-grid">
  <div class="fwb-wrap">

    <div class="fwb-book-grid__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="fwb-display fwb-book-grid__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.all_link_label != blank -%}
        <a href="{{ section.settings.all_link_url | default: '/collections/verlag' }}" class="fwb-book-grid__all-link fwb-label">{{ section.settings.all_link_label }}</a>
      {%- endif -%}
    </div>

    {%- if section.settings.collection != blank -%}
      {%- assign books = section.settings.collection.products -%}
    {%- else -%}
      {%- assign books = collections.all.products | limit: 4 -%}
    {%- endif -%}

    <div class="fwb-book-grid__books" style="--cols:{{ section.settings.columns }}">
      {%- for book in books limit: section.settings.columns -%}
        <a href="{{ book.url }}" class="fwb-book-grid__item">
          <div class="fwb-book-grid__image-wrap">
            {%- if book.featured_image != blank -%}
              <img
                src="{{ book.featured_image | img_url: '600x' }}"
                alt="{{ book.featured_image.alt | default: book.title | escape }}"
                loading="lazy"
              >
            {%- endif -%}
            <div class="fwb-book-grid__hover-cta">
              <span class="fwb-label">{{ section.settings.card_hover_label | default: 'Mehr erfahren →' }}</span>
            </div>
          </div>
          <div class="fwb-book-grid__info">
            <h3 class="fwb-book-grid__title">{{ book.title }}</h3>
            <p class="fwb-book-grid__price">ab {{ book.price_min | money }}</p>
          </div>
        </a>
      {%- endfor -%}
    </div>

  </div>
</div>

{% stylesheet %}
  .fwb-book-grid { padding-block: var(--fwb-section-pad); border-top: 1px solid var(--fwb-grey-200); }

  .fwb-book-grid__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: clamp(2.5rem, 5vw, 5rem);
    padding-bottom: clamp(1.5rem, 3vw, 2.5rem);
    border-bottom: 1px solid var(--fwb-grey-200);
  }

  .fwb-book-grid__heading { font-style: italic; font-weight: 300; }

  .fwb-book-grid__all-link {
    white-space: nowrap;
    color: var(--fwb-grey-500);
    transition: color var(--fwb-transition);
  }
  .fwb-book-grid__all-link:hover { color: var(--fwb-black); }

  .fwb-book-grid__books {
    display: grid;
    grid-template-columns: repeat(var(--cols, 4), 1fr);
    gap: clamp(1.5rem, 3vw, 3rem);
    align-items: start;
  }

  .fwb-book-grid__item {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    text-decoration: none;
    color: inherit;
  }

  .fwb-book-grid__image-wrap {
    position: relative;
    overflow: hidden;
    aspect-ratio: 3/4;
    background: var(--fwb-grey-100);
  }

  .fwb-book-grid__image-wrap img {
    width: 100%;
    height: 100%;
    padding: clamp(0.65rem, 1.6vw, 1.2rem);
    object-fit: contain;
    transition: transform 0.5s ease;
    display: block;
  }

  .fwb-book-grid__item:hover .fwb-book-grid__image-wrap img {
    transform: scale(1.03);
  }

  .fwb-book-grid__hover-cta {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.45);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .fwb-book-grid__hover-cta .fwb-label {
    color: var(--fwb-white);
    letter-spacing: 0.16em;
  }

  .fwb-book-grid__item:hover .fwb-book-grid__hover-cta { opacity: 1; }

  .fwb-book-grid__info {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .fwb-book-grid__title {
    font-family: var(--fwb-font-heading);
    font-size: clamp(0.95rem, 1.2vw, 1.15rem);
    font-weight: 400;
    line-height: 1.35;
    color: var(--fwb-black);
  }

  .fwb-book-grid__price {
    font-size: 0.78rem;
    color: var(--fwb-grey-500);
    font-weight: 400;
    letter-spacing: 0.02em;
  }

  @media (max-width: 900px) { .fwb-book-grid__books { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 540px) { .fwb-book-grid__books { grid-template-columns: 1fr; } .fwb-book-grid__header { flex-direction: column; gap: 0.5rem; } }
{% endstylesheet %}

{% schema %}
{
  "name": "Büchergitter",
  "settings": [
    { "type": "text", "id": "heading", "label": "Überschrift", "default": "Bereit zum Blättern." },
    { "type": "collection", "id": "collection", "label": "Kollektion" },
    {
      "type": "select", "id": "columns", "label": "Spalten",
      "options": [
        { "value": "2", "label": "2 Spalten" },
        { "value": "3", "label": "3 Spalten" },
        { "value": "4", "label": "4 Spalten" }
      ],
      "default": "4"
    },
    { "type": "text", "id": "all_link_label", "label": "Alle-ansehen Text", "default": "Alle ansehen →" },
    { "type": "url", "id": "all_link_url", "label": "Alle-ansehen Link" },
    { "type": "text", "id": "card_hover_label", "label": "Karte Hover-Text", "default": "Mehr erfahren →" }
  ],
  "presets": [{ "name": "Büchergitter" }]
}
{% endschema %}
