<div class="fwb-coming-soon">
  <div class="fwb-coming-soon__bg full-width">
    <img src="{{ 'verlag-books-overview.png' | asset_url }}" alt="" class="fwb-coming-soon__bg-img" loading="lazy" aria-hidden="true">
    <div class="fwb-coming-soon__overlay"></div>
  </div>

  <div class="fwb-wrap fwb-coming-soon__content">
    {%- if section.settings.heading != blank -%}
      <h2 class="fwb-display fwb-coming-soon__heading fwb-text-center">
        {{ section.settings.heading }}
      </h2>
    {%- endif -%}

    <div class="fwb-coming-soon__grid">
      <div class="fwb-coming-soon__book">
        <img src="{{ 'coming-soon-projektmanagement.png' | asset_url }}" alt="Bau- und Projektmanagement" loading="lazy">
        <p class="fwb-h3 fwb-coming-soon__title">Bau- und Projektmanagement</p>
      </div>
      <div class="fwb-coming-soon__book">
        <img src="{{ 'coming-soon-betonbau.png' | asset_url }}" alt="Betonbau" loading="lazy">
        <p class="fwb-h3 fwb-coming-soon__title">Betonbau</p>
      </div>
      <div class="fwb-coming-soon__book">
        <img src="{{ 'coming-soon-kalkulation.png' | asset_url }}" alt="Kalkulation und Preisberechnung" loading="lazy">
        <p class="fwb-h3 fwb-coming-soon__title">Kalkulation und Preisberechnung</p>
      </div>
      <div class="fwb-coming-soon__book">
        <img src="{{ 'coming-soon-beschaffung.png' | asset_url }}" alt="Nachhaltige und innovative Beschaffung" loading="lazy">
        <p class="fwb-h3 fwb-coming-soon__title">Nachhaltige und innovative Beschaffung</p>
      </div>
    </div>

    {%- if section.settings.note != blank -%}
      <p class="fwb-coming-soon__note fwb-body fwb-text-center">{{ section.settings.note }}</p>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .fwb-coming-soon {
    position: relative;
    padding-block: var(--fwb-section-pad);
  }

  .fwb-coming-soon__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .fwb-coming-soon__bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: grayscale(100%) brightness(1.1);
    opacity: 0.18;
  }

  .fwb-coming-soon__overlay {
    position: absolute;
    inset: 0;
    background: var(--fwb-white);
    opacity: 0.7;
  }

  .fwb-coming-soon__content {
    position: relative;
    z-index: 1;
  }

  .fwb-coming-soon__heading {
    margin-bottom: clamp(2.5rem, 5vw, 5rem);
    font-style: italic;
  }

  .fwb-coming-soon__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(1.5rem, 3vw, 3rem);
    align-items: start;
    margin-bottom: 2rem;
  }

  .fwb-coming-soon__book {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    opacity: 0.55;
    filter: grayscale(100%);
  }

  .fwb-coming-soon__book img {
    width: 100%;
    aspect-ratio: 3/4;
    object-fit: cover;
  }

  .fwb-coming-soon__title {
    font-size: clamp(0.9rem, 1.1vw, 1.05rem);
    color: var(--fwb-grey-700);
  }

  .fwb-coming-soon__note {
    max-width: 560px;
    margin-inline: auto;
    margin-top: 1.5rem;
    color: var(--fwb-grey-500);
    font-size: 0.85rem;
  }

  @media (max-width: 900px) {
    .fwb-coming-soon__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 540px) {
    .fwb-coming-soon__grid { grid-template-columns: 1fr; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Kommt bald",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Kommt bald. Baut auf Qualität."
    },
    {
      "type": "textarea",
      "id": "note",
      "label": "Hinweistext",
      "default": "Diese Bücher befinden sich aktuell in Arbeit. Die Inhalte werden entwickelt, strukturiert und sorgfältig aufgebaut. Weitere Informationen folgen bald."
    }
  ],
  "presets": [
    {
      "name": "Kommt bald"
    }
  ]
}
{% endschema %}
