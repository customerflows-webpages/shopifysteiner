<div class="fwb-coming-soon">
  <div class="fwb-coming-soon__bg">
    {%- if section.settings.bg_image != blank -%}
      <img src="{{ section.settings.bg_image | img_url: '2000x' }}" alt="" loading="lazy" aria-hidden="true">
    {%- else -%}
      <img src="{{ 'kommtbald-bg.png' | asset_url }}" alt="" loading="lazy" aria-hidden="true">
    {%- endif -%}
  </div>

  <div class="fwb-wrap fwb-coming-soon__content">
    {%- if section.settings.heading != blank -%}
      <h2 class="fwb-display fwb-coming-soon__heading fwb-text-center">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="fwb-coming-soon__grid" style="--cols:{{ section.settings.columns }}">
      {%- assign fallback_assets = 'kommtbald-bau-projektmanagement.png,kommtbald-betonbau.png,kommtbald-kalkulation.png,kommtbald-beschaffung.png' | split: ',' -%}
      {%- for block in section.blocks -%}
        <div class="fwb-coming-soon__book" {{ block.shopify_attributes }}>
          <div class="fwb-coming-soon__book-img-wrap">
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | img_url: '400x' }}" alt="{{ block.settings.title | escape }}" loading="lazy">
            {%- else -%}
              <img src="{{ fallback_assets[forloop.index0] | asset_url }}" alt="{{ block.settings.title | escape }}" loading="lazy">
            {%- endif -%}
          </div>
          {%- if block.settings.title != blank -%}
            <p class="fwb-coming-soon__title">{{ block.settings.title }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

    {%- if section.settings.note != blank -%}
      <p class="fwb-coming-soon__note fwb-body fwb-text-center">{{ section.settings.note }}</p>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .fwb-coming-soon {
    position: relative;
    overflow: hidden;
    padding-block: clamp(4rem, 8vw, 8rem);
  }

  .fwb-coming-soon__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .fwb-coming-soon__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 0.18;
    filter: grayscale(100%);
  }

  .fwb-coming-soon__content {
    position: relative;
    z-index: 1;
  }

  .fwb-coming-soon__heading {
    margin-bottom: clamp(2.5rem, 5vw, 5rem);
    font-weight: 400;
  }

  .fwb-coming-soon__grid {
    display: grid;
    grid-template-columns: repeat(var(--cols, 4), 1fr);
    gap: clamp(1.5rem, 3vw, 3rem);
    margin-bottom: clamp(2rem, 4vw, 3rem);
    align-items: end;
  }

  .fwb-coming-soon__book {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
    text-align: center;
  }

  .fwb-coming-soon__book-img-wrap {
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .fwb-coming-soon__book-img-wrap img {
    width: 70%;
    height: auto;
    object-fit: contain;
    filter: grayscale(10%);
    drop-shadow: 0 8px 24px rgba(0,0,0,0.15);
  }

  .fwb-coming-soon__title {
    font-family: var(--fwb-font-heading);
    font-size: clamp(0.9rem, 1.2vw, 1.1rem);
    font-weight: 400;
    color: var(--fwb-black);
    line-height: 1.3;
  }

  .fwb-coming-soon__note {
    max-width: 560px;
    margin-inline: auto;
    color: var(--fwb-grey-700);
    font-size: 0.85rem;
    line-height: 1.6;
    text-align: center;
  }

  @media (max-width: 900px) {
    .fwb-coming-soon__grid { grid-template-columns: repeat(2, 1fr); }
    .fwb-coming-soon__book-img-wrap img { width: 60%; }
  }
  @media (max-width: 540px) {
    .fwb-coming-soon__grid { grid-template-columns: repeat(2, 1fr); }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Kommt bald",
  "settings": [
    { "type": "text", "id": "heading", "label": "Überschrift", "default": "Kommt bald. Baut auf Qualität." },
    { "type": "image_picker", "id": "bg_image", "label": "Hintergrundbild (Bücher-Übersicht)" },
    { "type": "textarea", "id": "note", "label": "Hinweistext", "default": "Diese Bücher befinden sich aktuell in Arbeit. Die Inhalte werden entwickelt, strukturiert und sorgfältig aufgebaut. Weitere Informationen folgen bald." },
    {
      "type": "select", "id": "columns", "label": "Spalten",
      "options": [
        { "value": "2", "label": "2 Spalten" },
        { "value": "3", "label": "3 Spalten" },
        { "value": "4", "label": "4 Spalten" }
      ],
      "default": "4"
    }
  ],
  "blocks": [
    {
      "type": "book",
      "name": "Buch",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Buchbild" },
        { "type": "text", "id": "title", "label": "Buchtitel" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kommt bald",
      "blocks": [
        { "type": "book", "settings": { "title": "Bau- und Projektmanagement" } },
        { "type": "book", "settings": { "title": "Betonbau" } },
        { "type": "book", "settings": { "title": "Kalkulation und Preisberechnung" } },
        { "type": "book", "settings": { "title": "Nachhaltige und innovative Beschaffung" } }
      ]
    }
  ]
}
{% endschema %}
