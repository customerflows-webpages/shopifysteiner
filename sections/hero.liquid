<div class="fwb-hero full-width">
  <div class="fwb-hero__bg">
    {%- if section.settings.image != blank -%}
      <img
        src="{{ section.settings.image | img_url: '1800x' }}"
        alt="{{ section.settings.image.alt | escape }}"
        class="fwb-hero__img"
        loading="eager"
        fetchpriority="high"
      >
    {%- else -%}
      <img
        src="{{ 'hero-bg.jpg' | asset_url }}"
        alt=""
        class="fwb-hero__img"
        loading="eager"
        fetchpriority="high"
      >
    {%- endif -%}
    <div class="fwb-hero__overlay"></div>
  </div>

  <div class="fwb-hero__content fwb-wrap">
    {%- if section.settings.heading != blank -%}
      <h1 class="fwb-hero__heading fwb-display">{{ section.settings.heading }}</h1>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="fwb-hero__sub">{{ section.settings.subheading }}</p>
    {%- endif -%}
    {%- if section.settings.cta_label != blank -%}
      <a href="{{ section.settings.cta_url }}" class="fwb-btn fwb-hero__cta">
        {{ section.settings.cta_label }}
      </a>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .fwb-hero {
    position: relative;
    min-height: clamp(420px, 65vh, 700px);
    display: flex;
    align-items: center;
  }

  .fwb-hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .fwb-hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
    filter: grayscale(100%) contrast(1.05);
  }

  .fwb-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(0,0,0,0.18) 0%,
      rgba(0,0,0,0.08) 60%,
      rgba(0,0,0,0.04) 100%
    );
  }

  .fwb-hero__content {
    position: relative;
    z-index: 1;
    max-width: 760px;
    padding-top: 4rem;
    padding-bottom: 4rem;
  }

  .fwb-hero__heading {
    color: var(--fwb-white);
    text-shadow: 0 1px 20px rgba(0,0,0,0.15);
    font-size: clamp(2rem, 4.5vw, 3.8rem);
    font-weight: 300;
  }

  .fwb-hero__sub {
    color: rgba(255,255,255,0.85);
    font-size: clamp(0.85rem, 1.2vw, 1rem);
    margin-top: 1.2rem;
    max-width: 540px;
    line-height: 1.7;
  }

  .fwb-hero__cta {
    margin-top: 2rem;
    border-color: rgba(255,255,255,0.9);
    color: var(--fwb-white);
  }

  .fwb-hero__cta:hover {
    background: var(--fwb-white);
    color: var(--fwb-black);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hintergrundbild"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Überschrift",
      "default": "Fachkompetenz für Bau und Infrastruktur – präzise, praxisnah, zukunftsstark."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Unterzeile"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button Text"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
